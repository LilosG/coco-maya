---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  light?: boolean;
}
const { label, title, subtitle, image, imageAlt = "", light = false } = Astro.props;
---
<section class="relative pt-32 pb-20 px-6 overflow-hidden">
  {image && (
    <div class="absolute inset-0">
      <img src={image} alt={imageAlt} class="w-full h-full object-cover" width="1800" height="600" fetchpriority="high" />
      <div class:list={["absolute inset-0", light ? "bg-white/60" : "bg-[var(--color-dark)]/50"]}></div>
    </div>
  )}
  {!image && <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-teal)]/10 to-transparent"></div>}
  <div class:list={["relative z-10 max-w-4xl mx-auto text-center", image && !light ? "text-[var(--color-cream)]" : "text-[var(--color-dark)]"]}>
    {label && (
      <p class="font-[family-name:var(--font-stamp)] text-[var(--color-teal-light)] text-xs tracking-[0.3em] uppercase mb-4">{label}</p>
    )}
    <h1 class="font-[family-name:var(--font-display)] text-5xl sm:text-6xl lg:text-7xl leading-tight mb-4">{title}</h1>
    {subtitle && (
      <p class:list={["font-[family-name:var(--font-body)] text-lg max-w-2xl mx-auto leading-relaxed", image && !light ? "opacity-80" : "opacity-60"]}>{subtitle}</p>
    )}
    <slot />
  </div>
</section>
