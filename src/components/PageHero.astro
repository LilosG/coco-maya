---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  light?: boolean;
  tall?: boolean;
}
const { label, title, subtitle, image, imageAlt = "", light = false, tall = false } = Astro.props;
---
<section class:list={["relative overflow-hidden flex items-end", tall ? "min-h-[70vh]" : "min-h-[50vh]"]}>
  {image && (
    <div class="absolute inset-0">
      <img src={image} alt={imageAlt} class="w-full h-full object-cover" width="1800" height="700" fetchpriority="high" />
      <div class:list={["absolute inset-0", light ? "bg-white/50" : "bg-gradient-to-t from-black/75 via-black/30 to-black/20"]}></div>
    </div>
  )}
  {!image && <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-teal)]/8 to-transparent"></div>}
  <div class="relative z-10 w-full max-w-5xl mx-auto px-6 pb-16 pt-40">
    {label && (
      <p class:list={["section-label mb-4", image && !light ? "text-[var(--color-teal-light)]" : ""]}>{label}</p>
    )}
    <h1 class:list={[
      "font-[family-name:var(--font-display)] italic leading-none mb-4",
      tall ? "text-6xl sm:text-7xl lg:text-8xl" : "text-5xl sm:text-6xl lg:text-7xl",
      image && !light ? "text-white" : "text-[var(--color-dark)]"
    ]}>{title}</h1>
    {subtitle && (
      <p class:list={[
        "font-[family-name:var(--font-body)] text-lg max-w-2xl leading-relaxed",
        image && !light ? "text-white/80" : "text-[var(--color-dark)] opacity-60"
      ]}>{subtitle}</p>
    )}
    <slot />
  </div>
</section>
