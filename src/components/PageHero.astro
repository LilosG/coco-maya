---
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  tall?: boolean;
}
const { label, title, subtitle, image, imageAlt = "", tall = false } = Astro.props;
---

<section class:list={[
  "relative overflow-hidden flex items-center justify-start",
  tall ? "min-h-[75vh]" : "min-h-[55vh]"
]}>
  {image && (
    <div class="absolute inset-0">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover object-center"
        width="1800" height="900"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/40 to-black/10"></div>
    </div>
  )}
  {!image && (
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-teal)]/6 to-transparent"></div>
  )}

  <div class="relative z-10 w-full max-w-5xl mx-auto px-6 lg:px-10 pb-16 pt-44">
    {label && <span class="eyebrow-light">{label}</span>}
    <h1 class:list={[
      "font-[family-name:var(--font-display)] italic leading-[0.95] mb-5 max-w-3xl",
      tall ? "text-[clamp(3.5rem,8vw,6.5rem)]" : "text-[clamp(3rem,7vw,5.5rem)]",
      image ? "text-white" : "text-[var(--color-dark)]"
    ]}>
      {title}
    </h1>
    {subtitle && (
      <p class:list={[
        "font-[family-name:var(--font-body)] text-lg max-w-xl leading-relaxed",
        image ? "text-white/75" : "text-[var(--color-dark)]/60"
      ]}>
        {subtitle}
      </p>
    )}
    <slot />
  </div>
</section>
