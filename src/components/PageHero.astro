---
interface Props {
  label?: string;
  title: string;
  titleSuffix?: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  tall?: boolean;
}
const { label, title, titleSuffix, subtitle, image, imageAlt = "", tall = false } = Astro.props;
---

<section class:list={[
  "relative overflow-hidden flex items-center",
  tall ? "min-h-[80vh]" : "min-h-[60vh]"
]}>
  {image && (
    <div class="absolute inset-0">
      <img
        src={image}
        alt={imageAlt}
        class="w-full h-full object-cover object-center"
        width="1800" height="900"
        fetchpriority="high"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.45) 45%, rgba(0,0,0,0.15) 100%);"></div>
    </div>
  )}
  {!image && (
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-teal)]/6 to-transparent"></div>
  )}

  <div class="relative z-10 w-full max-w-5xl mx-auto px-6 lg:px-10 pb-20 pt-48">
    {label && <span class="eyebrow-light tracking-[0.25em]">{label}</span>}
    <h1 class:list={[
      "font-[family-name:var(--font-display)] italic leading-[0.92] mb-6",
      tall ? "text-[clamp(4rem,9vw,7rem)]" : "text-[clamp(3.5rem,8vw,6rem)]",
      image ? "text-white" : "text-[var(--color-dark)]"
    ]}>
      {title}
      {titleSuffix && (
        <span class:list={[
          "block font-[family-name:var(--font-stamp)] not-italic text-[clamp(0.85rem,1.8vw,1.15rem)] tracking-[0.08em] mt-3",
          image ? "text-white/75" : "text-[var(--color-dark)]/55"
        ]}>
          {titleSuffix}
        </span>
      )}
    </h1>
    {subtitle && (
      <p class:list={[
        "font-[family-name:var(--font-body)] text-lg max-w-xl leading-relaxed",
        image ? "text-white/80" : "text-[var(--color-dark)]/60"
      ]}>
        {subtitle}
      </p>
    )}
    <slot />
  </div>
</section>
