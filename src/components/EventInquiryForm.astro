---
import { SITE } from "../data/site";

interface Props {
  label?: string;
  subtitle?: string;
  formUrl?: string;
  ctaLabel?: string;
  dark?: boolean;
}

const {
  label = "Book Your Event",
  subtitle,
  formUrl = SITE.inquiryForm.url,
  ctaLabel = "Inquire About Your Event",
  dark = false,
} = Astro.props;
---

<section class:list={["eif-section", dark && "eif-section--dark"]}>
  <div class="eif-head">
    <span class:list={dark ? "eyebrow-light" : "eyebrow"}>{label}</span>
    {subtitle && (
      <p class:list={["eif-sub", dark && "eif-sub--dark"]}>{subtitle}</p>
    )}
  </div>

  <div class="eif-cta">
    <div class="eif-accent"></div>
    <a
      href={formUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary eif-cta-btn"
    >
      {ctaLabel}
    </a>
  </div>
</section>

<style>
  .eif-section {
    padding: 88px 24px 100px;
    background: var(--color-cream);
  }
  .eif-section--dark {
    background: var(--color-dark);
  }

  .eif-head {
    text-align: center;
    max-width: 520px;
    margin: 0 auto 2rem;
  }
  .eif-sub {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(23, 20, 16, 0.55);
    margin-top: 0.625rem;
  }
  .eif-sub--dark {
    color: rgba(255, 255, 255, 0.55);
  }

  .eif-cta {
    max-width: 680px;
    margin: 0 auto;
    background: white;
    box-shadow: 0 4px 16px rgba(23, 20, 16, 0.06), 0 24px 64px rgba(23, 20, 16, 0.12);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 56px 24px;
  }

  .eif-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(to right, var(--color-teal), var(--color-teal-light));
  }

  .eif-cta {
    position: relative;
  }

  .eif-cta-btn {
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .eif-section { padding: 64px 12px 80px; }
    .eif-cta { padding: 44px 20px; }
  }
</style>
