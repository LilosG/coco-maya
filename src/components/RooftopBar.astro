---
import Picture from "./Picture.astro";
interface Props {
  cocktailImage?: string;
  patioImage?: string;
  menuHref?: string;
  addressLine?: string;
}

const {
  cocktailImage = '/images/cocktails.jpg',
  patioImage = '/images/elevated-patio.jpg',
  menuHref = '/happy-hour',
  addressLine = '1660 India St · Little Italy',
} = Astro.props;
---

<section class="hh-section" aria-labelledby="hh-title">
  <div class="sec-head">
    <span class="eyebrow mx-auto block">Open Daily</span>
    <h2 id="hh-title" class="hh-title">Rooftop Patio &amp; Bar</h2>
    <p class="hh-sub">
      Craft cocktails and an open-air glass atrium bar —
      one of Little Italy's most distinctive rooftop settings, every day of the week.
    </p>
  </div>

  <div class="hh-grid">
    <!-- Card 1 — THE COCKTAIL PROGRAM -->
    <article class="hh-card">
      <div class="hh-photo">
        <Picture src={cocktailImage} alt="Coco Maya signature cocktails on the rooftop patio" loading="lazy" width="700" height="394" />
      </div>
      <div class="hh-body">
        <span class="hh-tag hh-tag--teal">★ Signature ★</span>
        <div class="hh-hours-row">
          <div class="hh-col">
            <div class="hh-label">The Pour</div>
            <div class="hh-big">Craft Cocktails</div>
            <div class="hh-sub-small">Fresh juice, small-batch spirits</div>
          </div>
          <div class="hh-divider"></div>
          <div class="hh-col hh-col--accent">
            <div class="hh-label">Signature</div>
            <div class="hh-big">Cocktail Tower</div>
            <div class="hh-sub-small">Four margaritas, fresh florals</div>
          </div>
        </div>
      </div>
    </article>

    <!-- Card 2 — WHERE -->
    <article class="hh-card">
      <div class="hh-photo">
        <Picture src={patioImage} alt="The elevated rooftop patio and bar area at Coco Maya" loading="lazy" width="700" height="394" />
      </div>
      <div class="hh-body">
        <span class="hh-tag hh-tag--accent">Where</span>
        <div class="hh-where">
          <div class="hh-label">Location</div>
          <div class="hh-big">Elevated Patio<br />&amp; Bar Area</div>
          <div class="hh-addr">{addressLine}</div>
        </div>
      </div>
    </article>
  </div>

  <div class="hh-cta">
    <a href={menuHref} class="btn-primary">SEE THE ROOFTOP PATIO</a>
  </div>
</section>

<style>
  .hh-section {
    background: var(--color-sand);
    padding: 96px 80px;
    font-family: var(--font-body);
    color: var(--color-dark);
  }

  /* Header */
  .sec-head { text-align: center; margin-bottom: 44px; }
  .hh-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.75rem, 5.5vw, 4.5rem);
    line-height: 1.02;
    letter-spacing: -0.01em;
    margin: 0.75rem 0 0;
    color: var(--color-dark);
  }
  .hh-sub {
    max-width: 540px; margin: 1rem auto 0;
    color: rgba(23,20,16,0.55); font-size: 0.9375rem; line-height: 1.55;
    font-family: var(--font-body);
  }

  /* Grid */
  .hh-grid {
    max-width: 1180px; margin: 0 auto;
    display: grid; grid-template-columns: 1.15fr 1fr; gap: 28px;
  }

  /* Card */
  .hh-card {
    background: var(--color-cream);
    border: 1px solid rgba(61,138,138,0.14);
    box-shadow: 0 2px 8px rgba(0,0,0,0.05), 0 8px 28px rgba(0,0,0,0.07);
    display: grid; grid-template-rows: 1fr auto;
    overflow: hidden; position: relative;
  }
  .hh-photo { display: block; position: relative; overflow: hidden; background: var(--color-sand-dark); aspect-ratio: 16 / 9; }
  .hh-photo :global(img) { display: block; width: 100%; height: 100%; object-fit: cover; object-position: center; }

  .hh-body { padding: 30px 36px 32px; position: relative; }
  .hh-tag {
    position: absolute; top: -22px; left: 44px;
    padding: 8px 14px;
    font-family: var(--font-stamp); font-size: 10px; font-weight: 500; letter-spacing: 0.3em;
    color: white; text-transform: uppercase;
  }
  .hh-tag--teal { background: var(--color-teal); }
  .hh-tag--accent { background: var(--color-teal-dark); }

  /* Hours row */
  .hh-hours-row {
    display: grid; grid-template-columns: 1fr 1px 1fr;
    align-items: center; gap: 28px;
  }
  .hh-divider { width: 1px; height: 60px; background: var(--color-sand-dark); justify-self: center; }
  .hh-col .hh-label {
    font-family: var(--font-stamp); font-size: 10px; font-weight: 500; letter-spacing: 0.26em;
    color: rgba(23,20,16,0.4); margin-bottom: 8px; text-transform: uppercase;
  }
  .hh-col--accent .hh-label { color: var(--color-teal-dark); }
  .hh-col .hh-big {
    font-family: var(--font-display); font-style: italic;
    font-size: 2rem; line-height: 1.05; color: var(--color-dark);
  }
  .hh-col .hh-sub-small { font-size: 12px; color: rgba(23,20,16,0.5); margin-top: 6px; font-family: var(--font-body); }

  /* Where */
  .hh-where .hh-label {
    font-family: var(--font-stamp); font-size: 10px; font-weight: 500; letter-spacing: 0.26em;
    color: rgba(23,20,16,0.4); margin-bottom: 8px; text-transform: uppercase;
  }
  .hh-where .hh-big {
    font-family: var(--font-display); font-style: italic;
    font-size: 1.75rem; line-height: 1.1; color: var(--color-dark); margin-bottom: 6px;
  }
  .hh-where .hh-addr { font-size: 14px; color: rgba(23,20,16,0.5); font-family: var(--font-body); }

  /* CTA */
  .hh-cta { display: flex; justify-content: center; margin-top: 44px; }

  /* Responsive */
  @media (max-width: 960px) {
    .hh-section { padding: 88px 40px; }
    .sec-head { margin-bottom: 48px; }
    .hh-grid { grid-template-columns: 1fr; gap: 24px; }
    .hh-body { padding: 32px 32px 36px; }
  }
  @media (max-width: 640px) {
    .hh-section { padding: 72px 20px; }
    .sec-head { margin-bottom: 40px; }
    .hh-body { padding: 28px 22px; }
    .hh-tag { left: 22px; }
    .hh-hours-row { grid-template-columns: 1fr; gap: 16px; }
    .hh-divider { display: none; }
    .hh-col .hh-big { font-size: 1.625rem; }
    .hh-where .hh-big { font-size: 1.5rem; }
    .hh-cta { margin-top: 40px; }
  }
</style>
