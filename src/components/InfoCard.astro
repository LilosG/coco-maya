---
interface Props {
  label: string;
  value: string;
  sub?: string;
  accent?: boolean;
}
const { label, value, sub, accent = false } = Astro.props;
---

<div class:list={["ic-card", accent && "ic-card--accent"]}>
  <div class="ic-card__bar"></div>
  <div class="ic-card__body">
    <span class="ic-card__label">{label}</span>
    <span class="ic-card__value">{value}</span>
    {sub && <span class="ic-card__sub">{sub}</span>}
  </div>
</div>
