---
import { getSingleton } from '../lib/content';
import Picture from "./Picture.astro";
interface Props {
  interiorImage?: string;
  address?: string;
  cityLine?: string;
  phone?: string;
  mapsHref?: string;
  openLine?: string;
  accentLabel?: string;
  accentValue?: string;
}

const [SITE, home] = await Promise.all([getSingleton("siteSettings"), getSingleton("home")]);
const content = home.findUs;
const {
  interiorImage = content.image,
  address = SITE.address.street,
  cityLine = `${SITE.address.neighborhood}, ${SITE.address.city}, ${SITE.address.state} ${SITE.address.zip}`,
  phone = SITE.phone.display,
  mapsHref = SITE.address.mapsUrl,
  mapsPlaceId = SITE.address.mapsPlaceId,
  openLine = SITE.serviceMessaging.openDaily,
  accentLabel = content.accentLabel,
  accentValue = SITE.serviceMessaging.openDaily,
} = Astro.props;

const telHref = `tel:+1${phone.replace(/[^0-9]/g, '')}`;
const mapsEmbedUrl = `https://www.google.com/maps/embed/v1/place?key=${import.meta.env.GOOGLE_MAPS_API_KEY}&q=place_id:${mapsPlaceId}`;
---

<section class="find-section" aria-labelledby="find-title">
  <div class="sec-head">
    <span class="eyebrow mx-auto block">{content.eyebrow}</span>
    <h2 id="find-title" class="find-title">{content.title}</h2>
  </div>

  <article class="find-card">
    <div class="photo-side">
      <div class="find-photo">
        <Picture src={interiorImage} alt={content.imageAlt} loading="lazy" width="700" height="600" />
      </div>
      <div class="map-badge" aria-hidden="false">
        <iframe
          title={`Map to ${address}`}
          src={mapsEmbedUrl}
          class="w-full h-full border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>

    <div class="info-side">
      <div class="place-eyebrow">{content.placeEyebrow}</div>
      <h3 class="place-name">{address}</h3>
      <p class="place-sub">{cityLine}</p>

      <div class="fu-fields">
        <div class="fu-field">
          <span class="fu-field-label">{content.openLabel}</span>
          <span class="fu-leader"></span>
          <span class="fu-value">{openLine}</span>
        </div>
        <div class="fu-field fu-field--accent">
          <span class="fu-field-label">{accentLabel}</span>
          <span class="fu-leader"></span>
          <span class="fu-value">{accentValue}</span>
        </div>
        <div class="fu-field">
          <span class="fu-field-label">{content.callLabel}</span>
          <span class="fu-leader"></span>
          <span class="fu-value">{phone}</span>
        </div>
      </div>

      <div class="find-actions">
        <a href={mapsHref} target="_blank" rel="noopener" class="btn-primary">{content.directionsLabel}</a>
        <a href={telHref} class="btn-outline">{phone}</a>
      </div>
    </div>
  </article>
</section>

<style>
  .find-section {
    background: var(--color-cream);
    padding: 96px 80px;
    font-family: var(--font-body);
    color: var(--color-dark);
  }

  /* Header */
  .sec-head { text-align: center; margin-bottom: 44px; }
  .find-title {
    font-family: var(--font-display); font-style: italic; font-weight: 400;
    font-size: clamp(2.75rem, 5.5vw, 4.5rem); line-height: 1.02;
    letter-spacing: -0.01em; margin: 0.75rem 0 0;
    color: var(--color-dark);
  }

  /* Card */
  .find-card {
    max-width: 1180px; margin: 0 auto;
    background: white;
    border: 1px solid rgba(61,138,138,0.14);
    box-shadow: 0 2px 8px rgba(0,0,0,0.05), 0 8px 28px rgba(0,0,0,0.07);
    display: grid; grid-template-columns: 1.1fr 1fr;
    overflow: hidden;
  }
  .photo-side { position: relative; min-height: 460px; max-height: 600px; }
  .find-photo { display: block; position: relative; overflow: hidden; background: var(--color-sand-dark); height: 100%; min-height: 460px; max-height: 600px; }
  .find-photo :global(img) { display: block; width: 100%; height: 100%; object-fit: cover; object-position: center; }

  /* Inset map badge */
  .map-badge {
    position: absolute; bottom: 22px; right: 22px;
    background: white; padding: 12px; width: 180px;
    box-shadow: 0 12px 30px rgba(0,0,0,0.22);
  }
  .map-badge .map {
    background: rgba(61,138,138,0.08);
    height: 110px; position: relative; overflow: hidden;
  }
  .map-badge .map svg { width: 100%; height: 100%; }
  .map-badge .map-label {
    margin-top: 8px;
    font-family: var(--font-stamp); font-size: 9px; letter-spacing: 0.22em;
    color: rgba(23,20,16,0.4); text-align: center; text-transform: uppercase;
  }

  /* Info side */
  .info-side {
    padding: 48px 52px 44px;
    display: flex; flex-direction: column; justify-content: center;
  }
  .place-eyebrow {
    font-family: var(--font-stamp); font-size: 11px; letter-spacing: 0.32em;
    color: var(--color-teal); font-weight: 500; text-transform: uppercase;
  }
  .place-name {
    font-family: var(--font-display); font-style: italic;
    font-size: 3.25rem; line-height: 0.98;
    margin: 16px 0 8px; color: var(--color-dark);
  }
  .place-sub { font-size: 15px; color: rgba(23,20,16,0.5); margin: 0 0 20px; font-family: var(--font-body); }

  /* Fields with dotted leader */
  .fu-field {
    display: grid; grid-template-columns: auto 1fr auto;
    align-items: baseline; gap: 14px;
    padding: 10px 0;
    border-bottom: 1px dotted var(--color-sand-dark);
  }
  .fu-field:last-child { border-bottom: none; }
  .fu-field-label {
    font-family: var(--font-stamp); font-size: 10px; letter-spacing: 0.24em;
    color: rgba(23,20,16,0.4); text-transform: uppercase;
  }
  .fu-leader { border-top: 1px dotted rgba(23,20,16,0.2); transform: translateY(-2px); }
  .fu-value {
    font-family: var(--font-display); font-style: italic;
    font-size: 19px; color: var(--color-dark);
  }
  .fu-field--accent .fu-field-label { color: var(--color-teal-dark); }

  /* Actions */
  .find-actions { display: flex; gap: 12px; margin-top: 28px; }
  .find-actions .btn-primary { flex: 1.3; }
  .find-actions .btn-outline { flex: 1; }

  /* Responsive */
  @media (max-width: 960px) {
    .find-section { padding: 88px 40px; }
    .sec-head { margin-bottom: 48px; }
    .find-card { grid-template-columns: 1fr; }
    .photo-side, .find-photo { min-height: 380px; }
    .info-side { padding: 48px 40px; }
    .place-name { font-size: 3.25rem; }
  }
  @media (max-width: 640px) {
    .find-section { padding: 72px 20px; }
    .sec-head { margin-bottom: 40px; }
    .photo-side, .find-photo { min-height: 320px; }
    .info-side { padding: 36px 24px 32px; }
    .place-eyebrow { font-size: 10px; letter-spacing: 0.26em; }
    .place-name { font-size: 2.625rem; margin-top: 16px; }
    .place-sub { font-size: 15px; margin-bottom: 24px; }

    .fu-field { grid-template-columns: auto 1fr; gap: 12px; padding: 12px 0; }
    .fu-leader { display: none; }
    .fu-value { font-size: 18px; justify-self: end; text-align: right; }

    .find-actions { flex-direction: column; gap: 10px; margin-top: 32px; }

    .map-badge { width: 140px; padding: 10px; bottom: 14px; right: 14px; }
    .map-badge .map { height: 80px; }
    .map-badge .map-label { font-size: 8px; }
  }
</style>
