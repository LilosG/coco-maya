---
// src/components/FindUs.astro
// Coco Maya — Find Us in Little Italy section
// Drop-in replacement for the current Find Us section.

interface Props {
  interiorImage?: string;
  address?: string;
  cityLine?: string;
  phone?: string;
  mapsHref?: string;
  openLine?: string;
}

const {
  interiorImage = '/images/find-us-interior.jpg',
  address = '1660 India St',
  cityLine = 'Little Italy, San Diego, CA 92101',
  phone = '(619) 943-9439',
  mapsHref = 'https://maps.google.com/?q=1660+India+St+San+Diego+CA+92101',
  openLine = 'Open Daily',
} = Astro.props;

const telHref = `tel:+1${phone.replace(/[^0-9]/g, '')}`;
---

<section class="find-section" aria-labelledby="find-title">
  <div class="sec-head">
    <div class="eyebrow">Come Visit</div>
    <h2 id="find-title" class="title">Find Us in Little Italy</h2>
  </div>

  <article class="find-card">
    <div class="photo-side">
      <div class="photo">
        <img src={interiorImage} alt="Coco Maya interior — In Love with the Coast neon wall" loading="lazy" />
      </div>
      <div class="map-badge" aria-hidden="true">
        <div class="map">
          <svg viewBox="0 0 180 110" preserveAspectRatio="none">
            <g stroke="#9CC4BF" stroke-width="0.8" opacity="0.7" fill="none">
              <line x1="0" y1="30" x2="180" y2="22" />
              <line x1="0" y1="60" x2="180" y2="54" />
              <line x1="0" y1="90" x2="180" y2="84" />
              <line x1="40" y1="0" x2="36" y2="110" />
              <line x1="100" y1="0" x2="96" y2="110" />
              <line x1="140" y1="0" x2="136" y2="110" />
            </g>
            <line x1="70" y1="0" x2="66" y2="110" stroke="#D67D5C" stroke-width="2" opacity="0.7" />
            <circle cx="68" cy="55" r="4.5" fill="#D67D5C" stroke="#fff" stroke-width="1.5" />
          </svg>
        </div>
        <div class="label">India St × W Ash</div>
      </div>
    </div>

    <div class="info-side">
      <div class="place-eyebrow">San Diego · Little Italy</div>
      <h3 class="place-name">{address}</h3>
      <p class="place-sub">{cityLine}</p>

      <div class="fields">
        <div class="field">
          <span class="label">Open</span>
          <span class="leader"></span>
          <span class="value">{openLine}</span>
        </div>
        <div class="field accent">
          <span class="label">Happy Hour</span>
          <span class="leader"></span>
          <span class="value">3 – 5pm every day</span>
        </div>
        <div class="field">
          <span class="label">Call</span>
          <span class="leader"></span>
          <span class="value">{phone}</span>
        </div>
      </div>

      <div class="find-actions">
        <a href={mapsHref} target="_blank" rel="noopener" class="btn btn-primary">GET DIRECTIONS</a>
        <a href={telHref} class="btn btn-ghost">{phone}</a>
      </div>
    </div>
  </article>
</section>

<style>
  .find-section {
    --cream-deep: #F1E8D2;
    --ink: #1A2624;
    --ink-soft: #5C6664;
    --ink-muted: #8A918F;
    --teal: #2E7873;
    --teal-deep: #1F5752;
    --teal-tint: #E2EEEC;
    --coral: #D67D5C;
    --paper-shadow: 0 1px 2px rgba(40,30,15,0.04), 0 30px 60px -22px rgba(40,30,15,0.18);
    --serif: "Cormorant Garamond", "Playfair Display", Georgia, serif;
    --sans: "Inter", "Helvetica Neue", system-ui, sans-serif;
    --mono: "JetBrains Mono", "IBM Plex Mono", monospace;

    background: #F8F1E1;
    padding: 80px 80px;
    font-family: var(--sans);
    color: var(--ink);
  }

  /* Header */
  .sec-head { text-align: center; margin-bottom: 44px; }
  .eyebrow {
    font-family: var(--sans);
    font-size: 12px; letter-spacing: 0.32em; font-weight: 500;
    color: var(--teal); text-transform: uppercase;
  }
  .title {
    font-family: var(--serif); font-style: italic; font-weight: 400;
    font-size: clamp(44px, 5.5vw, 72px); line-height: 1.02;
    letter-spacing: -0.01em; margin: 18px 0 0;
  }

  /* Card */
  .find-card {
    max-width: 1180px; margin: 0 auto;
    background: #fff;
    box-shadow: var(--paper-shadow);
    display: grid; grid-template-columns: 1.1fr 1fr;
    overflow: hidden;
  }
  .photo-side { position: relative; min-height: 460px; max-height: 600px; }
  .photo { display: block; position: relative; overflow: hidden; background: #E8D9B8; height: 100%; min-height: 460px; max-height: 600px; }
  .photo img { display: block; width: 100%; height: 100%; object-fit: cover; object-position: center; }

  /* Inset map badge */
  .map-badge {
    position: absolute; bottom: 22px; right: 22px;
    background: #fff; padding: 12px; width: 180px;
    box-shadow: 0 12px 30px rgba(0,0,0,0.22);
  }
  .map-badge .map {
    background: var(--teal-tint);
    height: 110px; position: relative; overflow: hidden;
  }
  .map-badge .map svg { width: 100%; height: 100%; }
  .map-badge .label {
    margin-top: 8px;
    font-family: var(--mono); font-size: 9px; letter-spacing: 0.22em;
    color: var(--ink-muted); text-align: center;
  }

  /* Info side */
  .info-side {
    padding: 48px 52px 44px;
    display: flex; flex-direction: column; justify-content: center;
  }
  .place-eyebrow {
    font-family: var(--sans); font-size: 11px; letter-spacing: 0.32em;
    color: var(--teal); font-weight: 500; text-transform: uppercase;
  }
  .place-name {
    font-family: var(--serif); font-style: italic;
    font-size: 52px; line-height: 0.98;
    margin: 16px 0 8px;
  }
  .place-sub { font-size: 15px; color: var(--ink-soft); margin: 0 0 20px; }

  /* Fields with dotted leader */
  .field {
    display: grid; grid-template-columns: auto 1fr auto;
    align-items: baseline; gap: 14px;
    padding: 10px 0;
    border-bottom: 1px dotted var(--cream-deep);
  }
  .field:last-child { border-bottom: none; }
  .field .label {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.24em;
    color: var(--ink-muted); text-transform: uppercase;
  }
  .field .leader { border-top: 1px dotted #C5BFAD; transform: translateY(-2px); }
  .field .value {
    font-family: var(--serif); font-style: italic;
    font-size: 19px; color: var(--ink);
  }
  .field.accent .label { color: var(--coral); }

  /* Actions */
  .find-actions { display: flex; gap: 12px; margin-top: 28px; }
  .btn {
    font-family: var(--sans); font-weight: 500; cursor: pointer;
    padding: 18px 36px; border: none; text-decoration: none;
    display: inline-block; text-align: center;
  }
  .btn-primary {
    background: var(--teal); color: #fff;
    font-size: 12px; letter-spacing: 0.3em; flex: 1.3;
    transition: background 0.2s ease;
  }
  .btn-primary:hover { background: var(--teal-deep); }
  .btn-ghost {
    background: transparent; color: var(--teal);
    border: 1.5px solid var(--teal);
    font-size: 12px; letter-spacing: 0.22em; flex: 1;
    transition: all 0.2s ease;
  }
  .btn-ghost:hover { background: var(--teal); color: #fff; }

  /* Responsive */
  @media (max-width: 960px) {
    .find-section { padding: 88px 40px; }
    .sec-head { margin-bottom: 48px; }
    .find-card { grid-template-columns: 1fr; }
    .photo-side, .photo { min-height: 380px; }
    .info-side { padding: 48px 40px; }
    .place-name { font-size: 52px; }
  }
  @media (max-width: 640px) {
    .find-section { padding: 72px 20px; }
    .sec-head { margin-bottom: 40px; }
    .title { font-size: 44px; }
    .photo-side, .photo { min-height: 320px; }
    .info-side { padding: 36px 24px 32px; }
    .place-eyebrow { font-size: 10px; letter-spacing: 0.26em; }
    .place-name { font-size: 42px; margin-top: 16px; }
    .place-sub { font-size: 15px; margin-bottom: 24px; }

    .field { grid-template-columns: auto 1fr; gap: 12px; padding: 12px 0; }
    .field .leader { display: none; }
    .field .value { font-size: 18px; justify-self: end; text-align: right; }

    .find-actions { flex-direction: column; gap: 10px; margin-top: 32px; }
    .btn { padding: 16px 24px; font-size: 11px; width: 100%; }

    .map-badge { width: 140px; padding: 10px; bottom: 14px; right: 14px; }
    .map-badge .map { height: 80px; }
    .map-badge .label { font-size: 8px; }
  }
</style>
