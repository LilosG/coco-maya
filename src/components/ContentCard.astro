---
interface Props {
  label: string;
  body: string;
}
const { label, body } = Astro.props;
---

<div class="cc-card">
  <div class="cc-card__top-bar"></div>
  <div class="cc-card__body">
    <span class="cc-card__label">{label}</span>
    <div class="cc-card__rule"></div>
    <p class="cc-card__body-text">{body}</p>
  </div>
</div>
