---
import Picture from "./Picture.astro";
interface Props {
  title: string;
  subtitle?: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  dark?: boolean;
  image?: string;
}
const {
  title,
  subtitle,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  dark = false,
  image,
} = Astro.props;

const isDark = dark || !!image;
const primaryTarget = (primaryHref.startsWith("http") || primaryHref.startsWith("mailto") || primaryHref.startsWith("tel")) ? "_blank" : undefined;
const primaryRel = primaryTarget === "_blank" ? "noopener noreferrer" : undefined;
const secondaryTarget = secondaryHref && (secondaryHref.startsWith("http") || secondaryHref.startsWith("mailto") || secondaryHref.startsWith("tel")) ? "_blank" : undefined;
const secondaryRel = secondaryTarget === "_blank" ? "noopener noreferrer" : undefined;
---

<section class:list={["relative py-24 px-6 overflow-hidden", isDark ? "bg-[var(--color-dark)]" : "bg-[var(--color-teal)]/6"]}>

  {image && (
    <div class="absolute inset-0">
      <Picture src={image} alt="" class="w-full h-full object-cover" width="1800" height="400" loading="lazy" />
      <div class="absolute inset-0 bg-[var(--color-dark)]/75"></div>
    </div>
  )}

  <div class="relative z-10 max-w-2xl mx-auto text-center">

    <div class:list={["mx-auto mb-7", isDark ? "rule-light" : "rule"]} style="margin-left: auto; margin-right: auto;"></div>

    <h2 class:list={[
      "font-[family-name:var(--font-display)] italic text-[clamp(2rem,5vw,3rem)] leading-tight mb-4",
      isDark ? "text-white" : "text-[var(--color-dark)]"
    ]}>
      {title}
    </h2>

    {subtitle && (
      <p class:list={[
        "font-[family-name:var(--font-body)] text-base leading-relaxed mb-10",
        isDark ? "text-white/60" : "text-[var(--color-dark)]/60"
      ]}>
        {subtitle}
      </p>
    )}

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={primaryHref} target={primaryTarget} rel={primaryRel} class="btn-primary">
        {primaryLabel}
      </a>
      {secondaryLabel && secondaryHref && (
        <a href={secondaryHref} target={secondaryTarget} rel={secondaryRel} class:list={[isDark ? "btn-ghost" : "btn-outline"]}>
          {secondaryLabel}
        </a>
      )}
    </div>
  </div>
</section>
