---
import { SITE } from "../data/site";
interface Props {
  title?: string;
  subtitle?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  dark?: boolean;
  image?: string;
}
const {
  title = "Ready to Visit?",
  subtitle = "Reserve your table at Coco Maya in Little Italy.",
  primaryLabel = "Reserve a Table",
  primaryHref = SITE.reservations.url,
  secondaryLabel,
  secondaryHref,
  dark = false,
  image,
} = Astro.props;

const isExternal = (href: string) => href.startsWith("http") || href.startsWith("mailto") || href.startsWith("tel");
---

<section class:list={["relative py-24 px-6 overflow-hidden", dark || image ? "bg-[var(--color-dark)]" : "bg-[var(--color-teal)]/6"]}>

  {image && (
    <div class="absolute inset-0">
      <img src={image} alt="" class="w-full h-full object-cover" width="1800" height="400" loading="lazy" />
      <div class="absolute inset-0 bg-[var(--color-dark)]/75"></div>
    </div>
  )}

  <div class="relative z-10 max-w-2xl mx-auto text-center">

    <div class:list={["mx-auto mb-7", dark || image ? "rule-light" : "rule"]} style="margin-left: auto; margin-right: auto;"></div>

    <h2 class:list={[
      "font-[family-name:var(--font-display)] italic text-[clamp(2rem,5vw,3rem)] leading-tight mb-4",
      dark || image ? "text-white" : "text-[var(--color-dark)]"
    ]}>
      {title}
    </h2>

    {subtitle && (
      <p class:list={[
        "font-[family-name:var(--font-body)] text-base leading-relaxed mb-10",
        dark || image ? "text-white/60" : "text-[var(--color-dark)]/60"
      ]}>
        {subtitle}
      </p>
    )}

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      
        href={primaryHref}
        target={isExternal(primaryHref) ? "_blank" : undefined}
        rel={isExternal(primaryHref) ? "noopener noreferrer" : undefined}
        class:list={[dark || image ? "btn-primary" : "btn-primary"]}
      >
        {primaryLabel}
      </a>
      {secondaryLabel && secondaryHref && (
        
          href={secondaryHref}
          target={isExternal(secondaryHref) ? "_blank" : undefined}
          rel={isExternal(secondaryHref) ? "noopener noreferrer" : undefined}
          class:list={[dark || image ? "btn-ghost" : "btn-outline"]}
        >
          {secondaryLabel}
        </a>
      )}
    </div>
  </div>
</section>
