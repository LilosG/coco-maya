---
import { SITE } from "../data/site";
interface Props {
  title?: string;
  subtitle?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  dark?: boolean;
  image?: string;
}
const {
  title = "Ready to Visit?",
  subtitle = "Reserve your table at Coco Maya in Little Italy.",
  primaryLabel = "Reserve a Table",
  primaryHref = SITE.reservations.url,
  secondaryLabel,
  secondaryHref,
  dark = false,
  image,
} = Astro.props;
---
<section class:list={["relative py-24 px-6 text-center overflow-hidden", dark ? "bg-[var(--color-dark)]" : "bg-[var(--color-cream)]"]}>
  {image && (
    <div class="absolute inset-0">
      <img src={image} alt="" class="w-full h-full object-cover" width="1800" height="400" loading="lazy" />
      <div class="absolute inset-0 bg-[var(--color-dark)]/70"></div>
    </div>
  )}
  <div class="relative z-10 max-w-2xl mx-auto">
    <div class="flex justify-center mb-6">
      <div class="w-12 h-px bg-[var(--color-teal)]"></div>
    </div>
    <h2 class:list={[
      "font-[family-name:var(--font-display)] text-3xl sm:text-4xl italic mb-4",
      dark || image ? "text-[var(--color-cream)]" : "text-[var(--color-dark)]"
    ]}>{title}</h2>
    {subtitle && (
      <p class:list={[
        "font-[family-name:var(--font-body)] mb-10 leading-relaxed text-base",
        dark || image ? "text-[var(--color-sand)] opacity-80" : "text-[var(--color-dark)] opacity-60"
      ]}>{subtitle}</p>
    )}
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={primaryHref}
        target={primaryHref.startsWith("http") ? "_blank" : undefined}
        rel={primaryHref.startsWith("http") ? "noopener noreferrer" : undefined}
        class:list={["btn-primary", dark || image ? "!bg-[var(--color-teal)] !border-[var(--color-teal)]" : ""]}>
        {primaryLabel}
      </a>
      {secondaryLabel && secondaryHref && (
        <a href={secondaryHref}
          target={secondaryHref.startsWith("http") ? "_blank" : undefined}
          rel={secondaryHref.startsWith("http") ? "noopener noreferrer" : undefined}
          class:list={["btn-outline", dark || image ? "!text-white !border-white hover:!bg-white hover:!text-[var(--color-teal)]" : ""]}>
          {secondaryLabel}
        </a>
      )}
    </div>
  </div>
</section>
