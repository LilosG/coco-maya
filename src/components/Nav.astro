---
import { SITE } from "../data/site";
const pathname = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

    <a href="/" aria-label="Coco Maya — Home" class="flex-shrink-0">
      <img src="/images/logo-teal.png" alt="Coco Maya by Miss Bs Little Italy San Diego"
        class="h-12 w-auto" width="180" height="48" />
    </a>

    <nav class="hidden lg:flex items-center gap-7" aria-label="Main navigation">
      {SITE.nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "font-[family-name:var(--font-stamp)] text-xs tracking-widest uppercase transition-colors duration-200",
            pathname === item.href || pathname.startsWith(item.href + "/")
              ? "text-[var(--color-teal)]"
              : "text-[var(--color-dark)] hover:text-[var(--color-teal)]",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="hidden lg:flex items-center gap-3">
      <a href={SITE.order.url} target="_blank" rel="noopener noreferrer"
        class="border border-[var(--color-teal)] text-[var(--color-teal)] font-[family-name:var(--font-stamp)] text-xs tracking-widest uppercase px-4 py-2 hover:bg-[var(--color-teal)] hover:text-[var(--color-cream)] transition-colors duration-200">
        Order
      </a>
      <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer"
        class="bg-[var(--color-teal)] text-[var(--color-cream)] font-[family-name:var(--font-stamp)] text-xs tracking-widest uppercase px-5 py-2 hover:bg-[var(--color-teal-dark)] transition-colors duration-200">
        Reserve
      </a>
    </div>

    <button id="mobile-menu-btn" class="lg:hidden text-[var(--color-dark)] p-2"
      aria-label="Open menu" aria-expanded="false">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
</header>

<div id="mobile-menu"
  class="fixed inset-0 z-40 bg-[var(--color-cream)] flex flex-col items-center justify-center gap-8 translate-x-full transition-transform duration-300 lg:hidden"
  aria-hidden="true">
  <button id="mobile-menu-close" class="absolute top-6 right-6 text-[var(--color-dark)] p-2" aria-label="Close menu">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  {SITE.nav.map((item) => (
    <a href={item.href}
      class="font-[family-name:var(--font-stamp)] text-2xl tracking-widest uppercase text-[var(--color-dark)] hover:text-[var(--color-teal)] transition-colors">
      {item.label}
    </a>
  ))}
  <div class="flex gap-4 mt-4">
    <a href={SITE.order.url} target="_blank" rel="noopener noreferrer"
      class="border border-[var(--color-teal)] text-[var(--color-teal)] font-[family-name:var(--font-stamp)] text-sm tracking-widest uppercase px-6 py-3 hover:bg-[var(--color-teal)] hover:text-[var(--color-cream)] transition-colors">
      Order Online
    </a>
    <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer"
      class="bg-[var(--color-teal)] text-[var(--color-cream)] font-[family-name:var(--font-stamp)] text-sm tracking-widest uppercase px-6 py-3 hover:bg-[var(--color-teal-dark)] transition-colors">
      Reserve
    </a>
  </div>
</div>

<script>
  const header = document.getElementById("site-header");
  const btn = document.getElementById("mobile-menu-btn");
  const closeBtn = document.getElementById("mobile-menu-close");
  const menu = document.getElementById("mobile-menu");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 60) {
      header?.classList.add("nav-scrolled");
    } else {
      header?.classList.remove("nav-scrolled");
    }
  });

  btn?.addEventListener("click", () => {
    menu?.classList.remove("translate-x-full");
    menu?.setAttribute("aria-hidden", "false");
    btn.setAttribute("aria-expanded", "true");
  });

  closeBtn?.addEventListener("click", () => {
    menu?.classList.add("translate-x-full");
    menu?.setAttribute("aria-hidden", "true");
    btn?.setAttribute("aria-expanded", "false");
  });
</script>
