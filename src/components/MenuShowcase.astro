---
interface ShowcaseItem {
  name: string;
  description?: string;
  image: string;
  imageAlt?: string;
}

interface Props {
  eyebrow: string;
  title: string;
  subtitle?: string;
  items: ShowcaseItem[];
  ctaLabel?: string;
  ctaHref?: string;
  dark?: boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  items,
  ctaLabel,
  ctaHref,
  dark = false,
} = Astro.props;

// Derive a WebP sibling path for each JPG so callers only ever pass one path.
const webpOf = (src: string) => src.replace(/\.(jpg|jpeg|png)$/i, ".webp");
---

<section class={`ms-section ${dark ? "ms-section--dark" : ""}`} aria-labelledby="ms-title">
  <div class="ms-head">
    <span class={dark ? "eyebrow-light" : "eyebrow"}>{eyebrow}</span>
    <h2 id="ms-title" class="ms-title">{title}</h2>
    {subtitle && <p class="ms-subtitle">{subtitle}</p>}
  </div>

  <div class="ms-grid" style={`--ms-cols:${Math.min(items.length, 4)}`}>
    {items.map((item) => (
      <figure class="ms-item">
        <div class="ms-photo">
          <picture>
            <source srcset={webpOf(item.image)} type="image/webp" />
            <img
              src={item.image}
              alt={item.imageAlt ?? item.name}
              width="800"
              height="1000"
              loading="lazy"
              decoding="async"
            />
          </picture>
        </div>
        <figcaption class="ms-caption">
          <span class="ms-name">{item.name}</span>
          {item.description && <span class="ms-desc">{item.description}</span>}
        </figcaption>
      </figure>
    ))}
  </div>

  {ctaLabel && ctaHref && (
    <div class="ms-cta">
      <a href={ctaHref} class="btn-outline">{ctaLabel}</a>
    </div>
  )}
</section>

<style>
  .ms-section {
    padding: 96px 80px;
    background: var(--color-cream);
  }
  .ms-section--dark {
    background: var(--color-dark);
  }

  .ms-head { text-align: center; margin-bottom: 48px; }
  .ms-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.25rem, 4.5vw, 3.75rem);
    line-height: 1.05;
    margin: 0.5rem auto 0;
    color: var(--color-dark);
  }
  .ms-section--dark .ms-title { color: white; }
  .ms-subtitle {
    max-width: 560px; margin: 1rem auto 0;
    color: rgba(23,20,16,0.55); font-size: 0.9375rem; line-height: 1.55;
    font-family: var(--font-body);
  }
  .ms-section--dark .ms-subtitle { color: rgba(255,255,255,0.6); }

  .ms-grid {
    max-width: 1280px; margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(var(--ms-cols, 4), 1fr);
    gap: 24px;
  }

  .ms-item { margin: 0; }
  .ms-photo {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-sand-dark);
    border: 1px solid rgba(61,138,138,0.14);
  }
  .ms-photo img,
  .ms-photo picture {
    display: block; width: 100%; height: 100%;
  }
  .ms-photo img {
    object-fit: cover; object-position: center;
    transition: transform 0.5s ease;
  }
  .ms-item:hover .ms-photo img { transform: scale(1.04); }

  .ms-caption {
    display: flex; flex-direction: column; gap: 4px;
    padding-top: 14px; text-align: center;
  }
  .ms-name {
    font-family: var(--font-display); font-style: italic;
    font-size: 1.25rem; color: var(--color-dark);
  }
  .ms-section--dark .ms-name { color: white; }
  .ms-desc {
    font-family: var(--font-body); font-size: 0.8125rem;
    color: rgba(23,20,16,0.5); line-height: 1.5;
  }
  .ms-section--dark .ms-desc { color: rgba(255,255,255,0.55); }

  .ms-cta { display: flex; justify-content: center; margin-top: 48px; }

  @media (max-width: 960px) {
    .ms-section { padding: 80px 40px; }
    .ms-grid { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  }
  @media (max-width: 560px) {
    .ms-section { padding: 64px 20px; }
    .ms-grid { grid-template-columns: 1fr; gap: 28px; }
    .ms-head { margin-bottom: 36px; }
  }
</style>
