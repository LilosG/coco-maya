---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import CTASection from "../../components/CTASection.astro";
import { SITE } from "../../data/site";
---
<BaseLayout
  title="The Space | Coco Maya | Glass Atrium & Elevated Patio Little Italy San Diego"
  description="Coco Maya features a stunning glass atrium bar, elevated outdoor patio, and private dining room in Little Italy San Diego. 1660 India St."
  image="/images/venue-hero-bar.jpg"
>
  <Nav />
  <PageHero label="The Venue" title="The Space" subtitle="A glass atrium, an elevated patio, and a teal bar in the heart of Little Italy. There is nothing else like it in San Diego." image="/images/venue-hero-bar.jpg" imageAlt="Coco Maya glass atrium bar Little Italy San Diego" />

  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center mb-24">
      <div>
        <p class="font-[family-name:var(--font-stamp)] text-[var(--color-teal)] text-xs tracking-[0.3em] uppercase mb-4">The Bar</p>
        <h2 class="font-[family-name:var(--font-display)] text-4xl text-[var(--color-dark)] italic mb-6">The Glass Atrium</h2>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)] opacity-70 leading-relaxed mb-4">
          The centerpiece of Coco Maya is the open-air glass atrium — a retractable roof that opens to the San Diego sky. Teal bar tiles, rattan bar chairs, hanging botanicals, and a cocktail program worth sitting down for.
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)] opacity-70 leading-relaxed">
          Whether the roof is open or closed, the atmosphere inside the atrium is unlike anything else in Little Italy.
        </p>
      </div>
      <div class="relative">
        <img src="/images/venue-bar-patio.jpg" alt="Glass atrium at Coco Maya Little Italy San Diego" class="w-full aspect-[4/5] object-cover" width="700" height="875" loading="lazy" />
        <div class="absolute -bottom-4 -right-4 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
      </div>
    </div>

    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1 relative">
        <img src="/images/venue-patio-skyline.jpg" alt="Coco Maya elevated patio with city skyline Little Italy San Diego" class="w-full aspect-[4/5] object-cover" width="700" height="875" loading="lazy" />
        <div class="absolute -top-4 -left-4 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
      </div>
      <div class="order-1 lg:order-2">
        <p class="font-[family-name:var(--font-stamp)] text-[var(--color-teal)] text-xs tracking-[0.3em] uppercase mb-4">Outdoor Dining</p>
        <h2 class="font-[family-name:var(--font-display)] text-4xl text-[var(--color-dark)] italic mb-6">The Elevated Patio</h2>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)] opacity-70 leading-relaxed mb-4">
          The outdoor patio at Coco Maya is one of the most distinctive dining spaces in San Diego. Pink striped umbrellas, lush tropical greenery, and the Little Italy skyline as the backdrop.
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)] opacity-70 leading-relaxed">
          Perfect for brunch, happy hour, and private events. The patio is available for full buyouts and partial reservations.
        </p>
      </div>
    </div>
  </section>

  <CTASection title="Experience It Yourself" subtitle="Reserve a table or inquire about a private event." primaryLabel="Reserve a Table" primaryHref={SITE.reservations.url} secondaryLabel="Private Events" secondaryHref="/private-events" />
  <Footer />
</BaseLayout>
