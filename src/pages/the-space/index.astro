---
import Picture from "../../components/Picture.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import CTASection from "../../components/CTASection.astro";
import { getOrderedCollection, getSingleton } from "../../lib/content";
import { breadcrumbSchema } from "../../lib/schema";

const [SITE, page, spaces] = await Promise.all([getSingleton("siteSettings"), getSingleton("spacePage"), getOrderedCollection("theSpaceSections")]);
const fill = (value: string) => value.replaceAll("{{street}}", SITE.address.street);
const schema = [
  breadcrumbSchema([
    { name: SITE.breadcrumbs.home, url: SITE.url },
    { name: page.breadcrumbLabel, url: `${SITE.url}/the-space` },
  ]),
];
---
<BaseLayout
  title={page.seo.title}
  description={fill(page.seo.descriptionTemplate)}
  image={page.seo.image}
  extraSchema={schema}
>
  <Nav />
  <PageHero
    label={page.hero.label}
    title={page.hero.title}
    titleSuffix={page.hero.titleSuffix}
    subtitle={page.hero.subtitle}
    image={page.hero.image}
    imageAlt={page.hero.imageAlt}
    tall={true}
  />

  <section class="bg-[var(--color-teal)]">
    <div class="max-w-4xl mx-auto px-6 grid grid-cols-3 divide-x divide-white/20 text-center">
      {spaces.map((item) => (
        <div class="px-6 py-5">
          <span class="eyebrow-light mb-1">{item.summaryLabel}</span>
          <p class="font-[family-name:var(--font-display)] italic text-white text-lg">{item.summaryValue}</p>
        </div>
      ))}
    </div>
  </section>

  {spaces.map((space) => (
    <section class="py-24 px-6 bg-[var(--color-cream)]">
      <div class:list={["max-w-5xl mx-auto grid lg:grid-cols-2 gap-20 items-center", space.reverse ? "lg:grid-flow-dense" : ""]}>
        <div class:list={[space.reverse ? "lg:col-start-2" : ""]}>
          <span class="eyebrow">{space.label}</span>
          <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-4">{space.title}</h2>
          <div class="rule"></div>
          <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-4 text-[1.0625rem]">{space.body1}</p>
          <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed text-[1.0625rem]">{space.body2}</p>
        </div>
        <div class:list={["relative", space.reverse ? "lg:col-start-1 lg:row-start-1" : ""]}>
          <Picture
            src={space.image}
            alt={space.imageAlt}
            class="w-full aspect-[4/5] object-cover"
            width="700" height="875"
            loading="lazy"
          />
          <div class:list={[
            "absolute w-full h-full border border-[var(--color-teal)]/20 -z-10",
            space.reverse ? "-top-5 -right-5" : "-bottom-5 -right-5"
          ]}></div>
        </div>
      </div>
    </section>
  ))}


  <!-- THE BAR SECTION -->
  <section class="py-24 px-6 bg-[var(--color-dark)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="eyebrow-light">{spaces[0].barDetail.eyebrow}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.25rem,4vw,3.5rem)] text-white leading-tight mb-6">
          {spaces[0].barDetail.title}
        </h2>
        <div class="rule-light"></div>
        <p class="font-[family-name:var(--font-body)] text-white/60 leading-relaxed mb-4">
          {spaces[0].barDetail.body1}
        </p>
        <p class="font-[family-name:var(--font-body)] text-white/60 leading-relaxed mb-10">
          {spaces[0].barDetail.body2}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/menu" class="btn-primary">{page.barCtas.menuLabel}</a>
          <a href="/happy-hour" class="btn-ghost">{page.barCtas.patioLabel}</a>
        </div>
      </div>
      <div class="relative">
        <Picture
          src={spaces[0].barDetail.image}
          alt={spaces[0].barDetail.imageAlt}
          class="w-full aspect-[16/10] object-cover object-center"
          width="700" height="875" loading="lazy"
        />
        <div class="absolute -top-4 -left-4 w-full h-full border border-[var(--color-teal)]/25 -z-10 pointer-events-none"></div>
      </div>
    </div>
  </section>

  <CTASection
    title={page.cta.title}
    subtitle={page.cta.subtitle}
    primaryLabel={page.cta.primaryLabel}
    primaryHref={SITE.reservations.url}
    secondaryLabel={page.cta.secondaryLabel}
    secondaryHref="/private-events"
    dark={true}
  />
  <Footer />
</BaseLayout>
