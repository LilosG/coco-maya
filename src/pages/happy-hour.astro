---
import Picture from "../components/Picture.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import CTASection from "../components/CTASection.astro";
import InfoCard from "../components/InfoCard.astro";
import ContentCard from "../components/ContentCard.astro";
import FAQSection from "../components/FAQSection.astro";
import { getOrderedCollection, getSingleton, resolveSiteTokens } from "../lib/content";
import { faqPageSchema, breadcrumbSchema } from "../lib/schema";

const [SITE, rawPage, rawFaqs] = await Promise.all([getSingleton("siteSettings"), getSingleton("happyHourPage"), getOrderedCollection("happyHourFaqs")]);
const page = resolveSiteTokens(rawPage, SITE);
const faqs = rawFaqs as { question: string; answer: string }[];
const fill = (value: string) => value.replaceAll("{{street}}", SITE.address.street).replaceAll("{{openDaily}}", SITE.serviceMessaging.openDailyLower);
const schema = [
  faqPageSchema(faqs),
  breadcrumbSchema([
    { name: SITE.breadcrumbs.home, url: SITE.url },
    { name: page.breadcrumbLabel, url: `${SITE.url}/happy-hour` },
  ]),
];
---
<BaseLayout
  title={page.seo.title}
  description={page.seo.description}
  image={page.seo.image}
  extraSchema={schema}
>
  <Nav />
  <PageHero
    label={page.hero.label}
    title={page.hero.title}
    titleSuffix={page.hero.titleSuffix}
    subtitle={page.hero.subtitle}
    image={page.hero.image}
    imageAlt={page.hero.imageAlt}
    tall={true}
  />

  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto">

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-20">
        {page.infoCards.map((card: any) => <InfoCard label={card.label} value={card.value} sub={card.subTemplate ? card.subTemplate.replace("{{street}}", SITE.address.street) : undefined} accent={card.accent} />)}
      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="eyebrow">{page.intro.eyebrow}</span>
          <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-4">
            {page.intro.title}
          </h2>
          <div class="rule"></div>
          <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-4 text-[1.0625rem]">
            {page.intro.body1}
          </p>
          <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-10 text-[1.0625rem]">
            {page.intro.body2}
          </p>
          <div class="flex flex-wrap gap-4">
            <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">{page.intro.reserveLabel}</a>
            <a href="/menu" class="btn-outline">{page.intro.menuLabel}</a>
          </div>
        </div>
        <div class="relative">
          <Picture
            src={page.intro.image}
            alt={page.intro.imageAlt}
            class="w-full aspect-square object-cover"
            width="600" height="600"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -right-4 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
        </div>
      </div>

      <div class="mt-20 grid grid-cols-1 sm:grid-cols-3 gap-5">
        {page.features.map((item: any) => (
          <ContentCard label={item.label} body={item.body} />
        ))}
      </div>

    </div>
  </section>

  <FAQSection faqs={faqs} label={page.faq.label} title={page.faq.title} />

  <CTASection
    title={page.cta.title}
    subtitle={fill(page.cta.subtitleTemplate)}
    primaryLabel={page.cta.primaryLabel}
    primaryHref={SITE.reservations.url}
    secondaryLabel={page.cta.secondaryLabel}
    secondaryHref={SITE.address.mapsUrl}
    dark={true}
  />
  <Footer />
</BaseLayout>
