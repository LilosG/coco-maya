---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import CTASection from "../components/CTASection.astro";
import InfoCard from "../components/InfoCard.astro";
import ContentCard from "../components/ContentCard.astro";
import FAQSection from "../components/FAQSection.astro";
import { SITE } from "../data/site";
import { faqPageSchema } from "../lib/schema";

const faqs = [
  {
    question: "Does Coco Maya have a happy hour?",
    answer:
      "Coco Maya doesn't currently run a discounted happy hour. The full cocktail program and the elevated rooftop patio are open and available every day, no special time window required.",
  },
  {
    question: "What are the best times to visit the rooftop patio?",
    answer:
      "The patio is open daily and works well any time, though late afternoon into early evening tends to have the best light for the glass atrium bar and skyline views.",
  },
  {
    question: "Do I need a reservation to sit on the patio?",
    answer:
      "Reservations are recommended, especially on weekends, but walk-ins are welcome on the patio based on availability.",
  },
];
const schema = [faqPageSchema(faqs)];
---
<BaseLayout
  title="Rooftop Bar & Patio in Little Italy San Diego | Coco Maya"
  description="Coco Maya's rooftop patio and glass atrium bar in Little Italy, San Diego. Craft cocktails, an elevated open-air setting, open daily. 1660 India St."
  image="/images/cocktail-negroni-patio.jpg"
  extraSchema={schema}
>
  <Nav />
  <PageHero
    label="Open Daily"
    title="Rooftop Patio & Bar"
    titleSuffix="Happy Hour in Little Italy, San Diego"
    subtitle="Craft cocktails and an open-air glass atrium, one of Little Italy's most distinctive rooftop settings."
    image="/images/cocktail-negroni-patio.jpg"
    imageAlt="Rooftop patio and glass atrium bar at Coco Maya Little Italy San Diego"
    tall={true}
  />

  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto">

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-20">
        <InfoCard label="Open" value="Daily" />
        <InfoCard label="Setting" value="Elevated Patio" accent={true} />
        <InfoCard label="Location" value="Glass Atrium Bar" sub="1660 India St, Little Italy" />
      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="eyebrow">The Rooftop Bar</span>
          <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-4">
            Little Italy's Rooftop Bar
          </h2>
          <div class="rule"></div>
          <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-4 text-[1.0625rem]">
            Coco Maya's glass atrium bar opens onto an elevated outdoor patio, one of San Diego's most distinctive rooftop settings, surrounded by tropical greenery with views over Little Italy.
          </p>
          <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-10 text-[1.0625rem]">
            The full craft cocktail program is available daily, no special time window required, whether you're stopping by after work or starting an evening out.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">Reserve a Table</a>
            <a href="/menu" class="btn-outline">See Full Menu</a>
          </div>
        </div>
        <div class="relative">
          <img
            src="/images/cocktail-negroni-patio.jpg"
            alt="Craft cocktail on the rooftop patio at Coco Maya"
            class="w-full aspect-square object-cover"
            width="600" height="600"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -right-4 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
        </div>
      </div>

      <div class="mt-20 grid grid-cols-1 sm:grid-cols-3 gap-5">
        {[
          { label: "Craft Cocktails", body: "House-made cocktails built around fresh juice, small-batch spirits, and seasonal ingredients." },
          { label: "Signature Tower", body: "Our pink cocktail tower, four frozen margaritas built for the table, is the one most photos end up featuring." },
          { label: "The Patio", body: "An open-air glass atrium setting, one of the more distinctive rooftop bars in Little Italy." },
        ].map((item) => (
          <ContentCard label={item.label} body={item.body} />
        ))}
      </div>

    </div>
  </section>

  <FAQSection faqs={faqs} label="Good to Know" title="Rooftop Bar FAQ" />

  <CTASection
    title="Visit the Rooftop"
    subtitle="1660 India St, Little Italy San Diego. Open daily."
    primaryLabel="Reserve a Table"
    primaryHref={SITE.reservations.url}
    secondaryLabel="Get Directions"
    secondaryHref={SITE.address.mapsUrl}
    dark={true}
  />
  <Footer />
</BaseLayout>
