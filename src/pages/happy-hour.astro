---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import CTASection from "../components/CTASection.astro";
import InfoCard from "../components/InfoCard.astro";
import ContentCard from "../components/ContentCard.astro";
import { SITE } from "../data/site";
---
<BaseLayout
  title="Happy Hour Little Italy San Diego | Coco Maya | Daily 3-5PM"
  description="Best happy hour in Little Italy San Diego. Coco Maya: discounted cocktails and bites every day 3-5PM. 1660 India St, San Diego CA."
  image="/images/cocktail-happy-hour-group.jpg"
>
  <Nav />
  <PageHero
    label="Every Day 3-5PM"
    title="Happy Hour"
    subtitle="Discounted cocktails, wines, and bites every day of the week on the elevated patio."
    image="/images/cocktail-happy-hour-group.jpg"
    imageAlt="Happy hour cocktails at Coco Maya Little Italy San Diego"
    tall={true}
  />

  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto">

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-20">
        <InfoCard label="Days" value={SITE.happyHour.days} />
        <InfoCard label="Hours" value={SITE.happyHour.hours} accent={true} />
        <InfoCard label="Location" value="Elevated Patio" sub="Glass Atrium, 1660 India St" />
      </div>

      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="eyebrow">The Details</span>
          <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-4">
            Little Italy Best Happy Hour
          </h2>
          <div class="rule"></div>
          <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-4 text-[1.0625rem]">
            Coco Maya runs daily happy hour from 3 to 5 PM. Discounted cocktails, wines, and select bites served on one of San Diego most distinctive patios under the glass atrium, surrounded by tropical greenery.
          </p>
          <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-10 text-[1.0625rem]">
            Whether coming from the office or starting the evening early, the elevated patio in Little Italy is the right call.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">Reserve a Table</a>
            <a href="/menu" class="btn-outline">See Full Menu</a>
          </div>
        </div>
        <div class="relative">
          <img
            src="/images/cocktail-negroni-patio.jpg"
            alt="Happy hour cocktails at Coco Maya"
            class="w-full aspect-square object-cover"
            width="600" height="600"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -right-4 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
        </div>
      </div>

      <div class="mt-20 grid grid-cols-1 sm:grid-cols-3 gap-5">
        {[
          { label: "Cocktails", body: "Discounted house cocktails and wines with rotating seasonal specials." },
          { label: "Bites",     body: "Select appetizers and small plates from the full Coco Maya kitchen." },
          { label: "The Patio", body: "San Diego best happy hour setting on the elevated glass atrium patio." },
        ].map((item) => (
          <ContentCard label={item.label} body={item.body} />
        ))}
      </div>

    </div>
  </section>

  <CTASection
    title="Join Us for Happy Hour"
    subtitle="1660 India St, Little Italy San Diego. Every day 3-5PM."
    primaryLabel="Reserve a Table"
    primaryHref={SITE.reservations.url}
    secondaryLabel="Get Directions"
    secondaryHref={SITE.address.mapsUrl}
    dark={true}
  />
  <Footer />
</BaseLayout>
