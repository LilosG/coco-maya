---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import FAQSection from "../components/FAQSection.astro";
import CTASection from "../components/CTASection.astro";
import { getOrderedCollection, getSingleton, resolveSiteTokens } from "../lib/content";
import { faqPageSchema, breadcrumbSchema } from "../lib/schema";
const [SITE, page, rawFaqs] = await Promise.all([getSingleton("siteSettings"), getSingleton("faqPage"), getOrderedCollection("generalFaqs")]);
const GENERAL_FAQS = resolveSiteTokens(rawFaqs, SITE).map((faq: any) => ({ question: faq.question, answer: faq.answer ?? faq.answerTemplate ?? "" }));

const schema = [
  faqPageSchema(GENERAL_FAQS),
  breadcrumbSchema([
    { name: SITE.breadcrumbs.home, url: SITE.url },
    { name: page.breadcrumbLabel, url: `${SITE.url}/faq` },
  ]),
];
---
<BaseLayout
  title={page.seo.title}
  description={page.seo.description}
  image={page.seo.image}
  extraSchema={schema}
>
  <Nav />

  <PageHero
    label={page.hero.label}
    title={page.hero.title}
    titleSuffix={page.hero.titleSuffix}
    subtitle={page.hero.subtitle}
  />

  <FAQSection faqs={GENERAL_FAQS} showHeading={false} />

  <CTASection
    title={page.cta.title}
    subtitle={page.cta.subtitle}
    primaryLabel={page.cta.primaryLabelTemplate.replace("{{phone}}", SITE.phone.display)}
    primaryHref={`tel:${SITE.phone.tel}`}
    secondaryLabel={page.cta.secondaryLabel}
    secondaryHref={`mailto:${SITE.email}`}
    dark={true}
  />
  <Footer />
</BaseLayout>
