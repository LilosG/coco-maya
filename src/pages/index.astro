---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import CTASection from "../components/CTASection.astro";
import InfoCard from "../components/InfoCard.astro";
import { SITE } from "../data/site";
import { FEATURED_COCKTAILS, FEATURED_FOOD, FEATURED_BRUNCH } from "../data/menu";
import { RECURRING_EVENTS } from "../data/events";
import HappyHour from "../components/HappyHour.astro";
import FindUs from "../components/FindUs.astro";

const todayHours = (() => {
  const d = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
  const h = SITE.hours.find(x => x.day === d[new Date().getDay()]);
  return h?.hours ?? "Closed";
})();

const infoBar = [
  { label: "Hours Today",     value: todayHours,              sub: null,                  href: null },
  { label: "Happy Hour",      value: SITE.happyHour.hours,    sub: SITE.happyHour.days,   href: "/happy-hour" },
  { label: "Weekend Brunch",  value: SITE.brunch.hours,       sub: SITE.brunch.days,      href: "/brunch" },
  { label: "Location",        value: SITE.address.neighborhood + ", SD", sub: "1660 India St", href: SITE.address.mapsUrl },
];
---

<BaseLayout
  title="Coco Maya | Rooftop Restaurant & Brunch in Little Italy San Diego"
  description="Modern American coastal cuisine, craft cocktails, and San Diego best brunch. Coco Maya by Miss Bs in Little Italy at 1660 India St, San Diego CA."
  image="/images/venue-hero-bar.jpg"
>
  <Nav />

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/venue-hero-bar.jpg"
        alt="Coco Maya rooftop glass atrium bar — restaurant in Little Italy San Diego"
        class="w-full h-full object-cover object-center"
        width="1800" height="1200"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/25 to-black/65"></div>
    </div>
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <span class="eyebrow-light mx-auto block">Little Italy, San Diego</span>
      <h1 class="font-[family-name:var(--font-display)] italic text-[clamp(4.5rem,12vw,9rem)] text-white leading-none mb-3">
        Coco Maya
      </h1>
      <p class="font-[family-name:var(--font-stamp)] text-white/70 text-xs tracking-[0.3em] uppercase mb-6">by Miss B's</p>
      <p class="font-[family-name:var(--font-body)] text-white/80 text-lg max-w-lg mx-auto mb-11 leading-relaxed">
        Modern American coastal cuisine, craft cocktails, and San Diego's best brunch. Open daily in the heart of Little Italy.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">Reserve a Table</a>
        <a href="/menu" class="btn-ghost">View the Menu</a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ── INFO BAR ──────────────────────────────────────── -->
  <section class="bg-[var(--color-teal)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/20">
      {infoBar.map((item, i) => (
        <div class="flex flex-col items-center justify-center py-6 px-4 text-center">
          <span class="eyebrow-light mb-2" style="color: rgba(255,255,255,0.55);">{item.label}</span>
          {item.href ? (
            <a
              href={item.href}
              target={item.href.startsWith("http") ? "_blank" : undefined}
              rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
              class="font-[family-name:var(--font-display)] italic text-white text-xl hover:text-white/80 transition-colors leading-tight"
            >
              {item.value}
            </a>
          ) : (
            <p class="font-[family-name:var(--font-display)] italic text-white text-xl leading-tight">{item.value}</p>
          )}
          {item.sub && <p class="text-white/50 text-xs font-[family-name:var(--font-body)] mt-1">{item.sub}</p>}
        </div>
      ))}
    </div>
  </section>

  <!-- ── BRAND STATEMENT ───────────────────────────────── -->
  <section class="py-28 px-6 bg-[var(--color-cream)]">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-20 items-center">
      <div>
        <span class="eyebrow">Rooftop Restaurant · Little Italy San Diego</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.5rem,5vw,4rem)] text-[var(--color-dark)] leading-[1.05] mb-5">
          Where Little Italy<br />
          <span class="text-[var(--color-teal)]">Comes to Drink Well</span>
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-4 text-[1.0625rem]">
          Coco Maya brings elevated modern American coastal cuisine to the heart of San Diego's Little Italy. An open-air glass atrium, a stunning teal bar, and a menu that takes both the food and the cocktails seriously.
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-10 text-[1.0625rem]">
          Daily happy hour, weekend brunch, and private dining that transforms any occasion. 1660 India St — right in the middle of everything.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/the-space" class="btn-primary">See The Space</a>
          <a href="/menu" class="btn-outline">View the Menu</a>
        </div>
      </div>
      <div class="relative">
        <img
          src="/images/venue-bar-patio.jpg"
          alt="Coco Maya rooftop patio and glass atrium bar — Little Italy San Diego restaurant"
          class="w-full aspect-[4/5] object-cover"
          width="800" height="1000"
          loading="lazy"
        />
        <div class="absolute -bottom-5 -right-5 w-full h-full border border-[var(--color-teal)]/25 -z-10"></div>
      </div>
    </div>
  </section>

  <!-- ── COCKTAILS ─────────────────────────────────────── -->
  <section class="py-28 px-6 bg-[var(--color-dark)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="eyebrow-light mx-auto block">Craft Program</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.5rem,5vw,4rem)] text-white">
          Craft Cocktails &amp; Happy Hour in Little Italy San Diego
        </h2>
        <p class="font-[family-name:var(--font-body)] text-white/50 mt-4 max-w-md mx-auto">
          Craft cocktails built for the elevated patio.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {FEATURED_COCKTAILS.map((drink) => (
          <div class="cm-media-card group">
            <div class="aspect-square overflow-hidden">
              <img
                src={drink.image}
                alt={`${drink.name} cocktail at Coco Maya Little Italy San Diego`}
                class="w-full h-full object-cover"
                width="400" height="400"
                loading="lazy"
              />
            </div>
            <div class="p-5 border-t border-[var(--color-teal)]/15">
              <h3 class="font-[family-name:var(--font-stamp)] text-[var(--color-dark)] text-sm tracking-wide mb-1.5">{drink.name}</h3>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/50 text-xs leading-relaxed">{drink.description}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/menu" class="btn-ghost">Full Cocktail Menu</a>
      </div>
    </div>
  </section>

  <!-- ── BRUNCH ─────────────────────────────────────────── -->
  <section class="relative py-32 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/food-tacos-patio.jpg"
        alt="Weekend brunch at Coco Maya — best brunch in Little Italy San Diego"
        class="w-full h-full object-cover object-center"
        width="1800" height="900"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/40 to-black/70"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto text-center px-6">
      <span class="eyebrow-light mx-auto block">Saturday & Sunday 11AM - 3PM</span>
      <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(3.5rem,8vw,6rem)] text-white leading-none mb-3">
        Weekend Brunch in Little Italy San Diego
      </h2>
      <p class="font-[family-name:var(--font-script)] text-white/75 text-3xl mb-8">in Little Italy</p>
      <p class="font-[family-name:var(--font-body)] text-white/80 text-lg max-w-xl mx-auto mb-11 leading-relaxed">
        San Diego's best brunch on the elevated patio. Bottomless options, modern coastal plates, and craft cocktails every Saturday and Sunday.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/brunch" class="btn-white">See Brunch Menu</a>
        <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-ghost">Reserve a Table</a>
      </div>
    </div>
  </section>

  <!-- ── FOOD ───────────────────────────────────────────── -->
  <section class="py-28 px-6 bg-[var(--color-cream)]">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-14 items-end mb-14">
        <div>
          <span class="eyebrow">The Kitchen</span>
          <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.5rem,5vw,4rem)] text-[var(--color-dark)] leading-tight">
            Rooftop Dining<br />in Little Italy San Diego
          </h2>
        </div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/60 leading-relaxed text-[1.0625rem] lg:pb-2">
          Modern American coastal cuisine built around fresh ingredients, bold flavors, and plates worth photographing. From skirt steak to lobster flatbread.
        </p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        {FEATURED_FOOD.map((item) => (
          <div class="group relative overflow-hidden aspect-square">
            <img
              src={item.image}
              alt={`${item.name} at Coco Maya San Diego Little Italy`}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              width="500" height="500"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <h3 class="font-[family-name:var(--font-stamp)] text-white text-sm tracking-wide">{item.name}</h3>
              <p class="font-[family-name:var(--font-body)] text-white/60 text-xs mt-0.5 leading-snug line-clamp-2">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/menu" class="btn-outline">Full Food Menu</a>
      </div>
    </div>
  </section>

  <!-- ── HAPPY HOUR ─────────────────────────────────────── -->
  {/* OLD Happy Hour — kept for rollback
  <section class="py-28 px-6 bg-[var(--color-sand-dark)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="eyebrow">Every Day</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.5rem,5vw,4rem)] text-[var(--color-dark)] mb-4 leading-tight">
          Happy Hour in Little Italy San Diego
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-10 text-[1.0625rem]">
          Discounted cocktails, wines, and select bites every single day of the week. The elevated patio at its most accessible.
        </p>
        <a href="/happy-hour" class="btn-primary">See Happy Hour Details</a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <InfoCard label="Days" value={SITE.happyHour.days} />
        <InfoCard label="Hours" value={SITE.happyHour.hours} accent={true} />
        <div class="col-span-2">
          <InfoCard label="Location" value="Elevated Patio & Glass Atrium" sub="1660 India St, Little Italy" />
        </div>
      </div>
    </div>
  </section>
  */}
  <HappyHour menuHref="/happy-hour" />

  <!-- ── PRIVATE EVENTS ─────────────────────────────────── -->
  <section class="py-28 px-6 bg-[var(--color-cream)]">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-20 items-center">
      <div class="relative">
        <img
          src="/images/events-private-dining-1.jpg"
          alt="Private event venue in Little Italy San Diego — Coco Maya rooftop dining"
          class="w-full aspect-[3/4] object-cover"
          width="800" height="1067"
          loading="lazy"
        />
        <div class="absolute -top-5 -left-5 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
      </div>
      <div>
        <span class="eyebrow">Group Bookings</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.5rem,5vw,4rem)] text-[var(--color-dark)] leading-tight mb-4">
          Private Events<br />in Little Italy
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-8 text-[1.0625rem]">
          Birthdays, bachelorette parties, rehearsal dinners, corporate events. Coco Maya provides a private event space in San Diego that your guests will actually talk about.
        </p>
        <div class="mb-10">
          {["Bachelorette Parties", "Birthday Celebrations", "Rehearsal Dinners", "Corporate Events", "Baby Showers"].map((item) => (
            <div class="cm-event-item">
              <span class="cm-event-item-dot"></span>
              <span class="cm-event-item-label">{item}</span>
            </div>
          ))}
        </div>
        <a href="/private-events" class="btn-primary">Inquire About Your Event</a>
      </div>
    </div>
  </section>

  <!-- ── STATS BAR ──────────────────────────────────────── -->
  <section class="bg-[var(--color-dark)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="cm-dark-grid" style="grid-template-columns: repeat(4, 1fr);">
        {[
          { number: "4.5", unit: "★", label: "Google Rating", sub: "Little Italy" },
          { number: "Daily", unit: "", label: "Happy Hour", sub: "3:00 – 5:00 PM" },
          { number: "Sat & Sun", unit: "", label: "Weekend Brunch", sub: "11 AM – 3 PM" },
          { number: "Open", unit: " Daily", label: "1660 India St", sub: "San Diego, CA" },
        ].map((stat) => (
          <div class="cm-dark-grid-cell py-14">
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-teal-light)] text-3xl sm:text-4xl mb-2">
              {stat.number}<span class="text-2xl">{stat.unit}</span>
            </p>
            <p class="font-[family-name:var(--font-stamp)] text-white text-xs tracking-widest uppercase mb-1">{stat.label}</p>
            <p class="font-[family-name:var(--font-body)] text-white/35 text-xs">{stat.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FIND US ─────────────────────────────────────────── -->
  {/* OLD Find Us — kept for rollback
  <section class="py-28 px-6 bg-[var(--color-cream)]">
    <div class="max-w-3xl mx-auto text-center">
      <span class="eyebrow mx-auto block">Come Visit</span>
      <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.5rem,5vw,4rem)] text-[var(--color-dark)] mb-8">
        Rooftop Restaurant · 1660 India St · Little Italy San Diego
      </h2>
      <div class="cm-card max-w-sm mx-auto mb-10 text-left">
        <div class="flex gap-4 items-start mb-5">
          <div class="w-8 h-8 bg-[var(--color-teal)]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-[var(--color-teal)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-xl leading-snug">
              <a href={SITE.address.mapsUrl} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-teal)] transition-colors">
                {SITE.address.street}
              </a>
            </p>
            <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/45 text-sm mt-1">{SITE.address.neighborhood}, {SITE.address.city}, {SITE.address.state} {SITE.address.zip}</p>
          </div>
        </div>
        <div class="border-t border-[var(--color-teal)]/10 pt-4">
          <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/50 text-sm">Open Daily &bull; Happy Hour 3–5PM Every Day</p>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={SITE.address.mapsUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">Get Directions</a>
        <a href={`tel:${SITE.phone.tel}`} class="btn-outline">{SITE.phone.display}</a>
      </div>
    </div>
  </section>
  */}
  <FindUs
    address={SITE.address.street}
    cityLine={`${SITE.address.neighborhood}, ${SITE.address.city}, ${SITE.address.state} ${SITE.address.zip}`}
    phone={SITE.phone.display}
    mapsHref={SITE.address.mapsUrl}
  />

  <Footer />
</BaseLayout>
