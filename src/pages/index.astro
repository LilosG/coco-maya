---
import Picture from "../components/Picture.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { getOrderedCollection, getSingleton, resolveSiteTokens } from "../lib/content";
import RooftopBar from "../components/RooftopBar.astro";
import FindUs from "../components/FindUs.astro";

const [SITE, rawHome, FEATURED_COCKTAILS, FEATURED_FOOD, rawPrivateEventTypes] = await Promise.all([
  getSingleton("siteSettings"),
  getSingleton("home"),
  getOrderedCollection("menuCocktails"),
  getOrderedCollection("menuDinner"),
  getOrderedCollection("privateEventTypes"),
]);
const home = resolveSiteTokens(rawHome, SITE);
const PRIVATE_EVENT_TYPES = resolveSiteTokens(rawPrivateEventTypes, SITE);
const fill = (value: string, replacements: Record<string, string>) => Object.entries(replacements).reduce((text, [key, replacement]) => text.replaceAll(`{{${key}}}`, replacement), value);
const todayHours = (() => {
  const d = SITE.weekdaysSundayFirst;
  const h = SITE.hours.find((x: any) => x.day === d[new Date().getDay()]);
  return h?.hours ?? home.infoBar.closed;
})();

const infoBar = [
  { label: home.infoBar.hoursLabel, value: todayHours, sub: null, href: null },
  { label: home.infoBar.rooftopLabel, value: SITE.serviceMessaging.openDaily, sub: home.infoBar.rooftopSub, href: "/happy-hour" },
  { label: home.infoBar.brunchLabel, value: SITE.service.brunch.shortTagline, sub: home.infoBar.brunchSub, href: "/brunch" },
  { label: home.infoBar.locationLabel, value: SITE.address.neighborhood + ", SD", sub: fill(home.infoBar.locationSubTemplate, { street: SITE.address.street }), href: SITE.address.mapsUrl },
];
---

<BaseLayout
  title={home.seo.title}
  description={home.seo.description}
  image={home.seo.image}
>
  <Nav />

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <Picture
        src={home.hero.image}
        alt={home.hero.imageAlt}
        class="w-full h-full object-cover object-center"
        width="1800" height="1200"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/25 to-black/65"></div>
    </div>
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <span class="eyebrow-light mx-auto block">{home.hero.eyebrow}</span>
      <h1 class="font-[family-name:var(--font-display)] italic text-[clamp(4.5rem,12vw,9rem)] text-white leading-none mb-3">
        {home.hero.title}
        <span class="block font-[family-name:var(--font-stamp)] not-italic text-[clamp(0.95rem,2.2vw,1.35rem)] tracking-[0.08em] text-white/75 mt-3">
          {home.hero.titleSuffix}
        </span>
      </h1>
      <p class="font-[family-name:var(--font-stamp)] text-white/70 text-xs tracking-[0.3em] uppercase mb-6">{home.hero.byline}</p>
      <p class="font-[family-name:var(--font-body)] text-white/80 text-lg max-w-lg mx-auto mb-11 leading-relaxed">
        {home.hero.body}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">{home.hero.primaryLabel}</a>
        <a href="/menu" class="btn-ghost">{home.hero.secondaryLabel}</a>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ── INFO BAR ──────────────────────────────────────── -->
  <section class="bg-[var(--color-teal)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/20">
      {infoBar.map((item) => (
        <div class="flex flex-col items-center justify-center py-6 px-4 text-center">
          <span class="eyebrow-light mb-2" style="color: rgba(255,255,255,0.55);">{item.label}</span>
          {item.href ? (
            <a
              href={item.href}
              target={item.href.startsWith("http") ? "_blank" : undefined}
              rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
              class="font-[family-name:var(--font-display)] italic text-white text-xl hover:text-white/80 transition-colors leading-tight"
            >
              {item.value}
            </a>
          ) : (
            <p class="font-[family-name:var(--font-display)] italic text-white text-xl leading-tight">{item.value}</p>
          )}
          {item.sub && <p class="text-white/50 text-xs font-[family-name:var(--font-body)] mt-1">{item.sub}</p>}
        </div>
      ))}
    </div>
  </section>

  <!-- ── BRAND STATEMENT ───────────────────────────────── -->
  <section class="py-28 px-6 bg-[var(--color-cream)]">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-20 items-center">
      <div>
        <span class="eyebrow">{home.brand.eyebrow}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.5rem,5vw,4rem)] text-[var(--color-dark)] leading-[1.05] mb-5">
          {home.brand.titleLine1}<br />
          <span class="text-[var(--color-teal)]">{home.brand.titleLine2}</span>
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-4 text-[1.0625rem]">
          {home.brand.body1}
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-10 text-[1.0625rem]">
          {fill(home.brand.body2Template, { street: SITE.address.street })}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/the-space" class="btn-primary">{home.brand.primaryLabel}</a>
          <a href="/menu" class="btn-outline">{home.brand.secondaryLabel}</a>
        </div>
      </div>
      <div class="relative">
        <Picture
          src={home.brand.image}
          alt={home.brand.imageAlt}
          class="w-full aspect-[4/5] object-cover"
          width="800" height="1000"
          loading="lazy"
        />
        <div class="absolute -bottom-5 -right-5 w-full h-full border border-[var(--color-teal)]/25 -z-10"></div>
      </div>
    </div>
  </section>

  <!-- ── COCKTAILS ─────────────────────────────────────── -->
  <section class="py-28 px-6 bg-[var(--color-dark)]">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <span class="eyebrow-light mx-auto block">{home.cocktails.eyebrow}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.5rem,5vw,4rem)] text-white">
          {home.cocktails.title}
        </h2>
        <p class="font-[family-name:var(--font-body)] text-white/50 mt-4 max-w-md mx-auto">
          {home.cocktails.subtitle}
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {FEATURED_COCKTAILS.map((drink) => (
          <div class="cm-media-card group">
            <div class="aspect-square overflow-hidden">
              <picture>
                <source srcset={drink.image.replace(/\.(jpg|jpeg|png)$/i, ".webp")} type="image/webp" />
                <Picture
                  src={drink.image}
                  alt={fill(home.cocktails.imageAltTemplate, { name: drink.name })}
                  class="w-full h-full object-cover"
                  width="400" height="400"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
            </div>
            <div class="p-5 border-t border-[var(--color-teal)]/15">
              <h3 class="font-[family-name:var(--font-stamp)] text-[var(--color-dark)] text-sm tracking-wide mb-1.5">{drink.name}</h3>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/50 text-xs leading-relaxed">{drink.description}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <a href="/menu" class="btn-ghost">{home.cocktails.ctaLabel}</a>
      </div>
    </div>
  </section>

  <!-- ── BRUNCH ─────────────────────────────────────────── -->
  <section class="relative py-32 overflow-hidden">
    <div class="absolute inset-0">
      <Picture
        src={home.brunch.image}
        alt={home.brunch.imageAlt}
        class="w-full h-full object-cover object-center"
        width="1800" height="900"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/40 to-black/70"></div>
    </div>
    <div class="relative z-10 max-w-3xl mx-auto text-center px-6">
      <span class="eyebrow-light mx-auto block">{home.brunch.eyebrow}</span>
      <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(3.5rem,8vw,6rem)] text-white leading-none mb-3">
        {home.brunch.title}
      </h2>
      <p class="font-[family-name:var(--font-script)] text-white/75 text-3xl mb-8">{home.brunch.script}</p>
      <p class="font-[family-name:var(--font-body)] text-white/80 text-lg max-w-xl mx-auto mb-11 leading-relaxed">
        {home.brunch.body}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/brunch" class="btn-white">{home.brunch.primaryLabel}</a>
        <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-ghost">{home.brunch.secondaryLabel}</a>
      </div>
    </div>
  </section>

  <!-- ── FOOD ───────────────────────────────────────────── -->
  <section class="py-28 px-6 bg-[var(--color-cream)]">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-14 items-end mb-14">
        <div>
          <span class="eyebrow">{home.food.eyebrow}</span>
          <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.5rem,5vw,4rem)] text-[var(--color-dark)] leading-tight">
            {home.food.titleLine1}<br />{home.food.titleLine2}
          </h2>
        </div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/60 leading-relaxed text-[1.0625rem] lg:pb-2">
          {home.food.body}
        </p>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
        {FEATURED_FOOD.map((item) => (
          <div class="group relative overflow-hidden aspect-square">
            <picture>
              <source srcset={item.image.replace(/\.(jpg|jpeg|png)$/i, ".webp")} type="image/webp" />
              <Picture
                src={item.image}
                alt={fill(home.food.imageAltTemplate, { name: item.name })}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                width="500" height="500"
                loading="lazy"
                decoding="async"
              />
            </picture>
            <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <h3 class="font-[family-name:var(--font-stamp)] text-white text-sm tracking-wide">{item.name}</h3>
              <p class="font-[family-name:var(--font-body)] text-white/60 text-xs mt-0.5 leading-snug line-clamp-2">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/menu" class="btn-outline">{home.food.ctaLabel}</a>
      </div>
    </div>
  </section>

  <!-- ── ROOFTOP BAR ─────────────────────────────────────── -->
  <RooftopBar menuHref="/happy-hour" addressLine={`${SITE.address.street} · ${SITE.address.neighborhood}`} />

  <!-- ── PRIVATE EVENTS ─────────────────────────────────── -->
  <section class="py-28 px-6 bg-[var(--color-cream)]">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-20 items-center">
      <div class="relative">
        <Picture
          src={home.privateEvents.image}
          alt={home.privateEvents.imageAlt}
          class="w-full aspect-[3/4] object-cover"
          width="800" height="1067"
          loading="lazy"
        />
        <div class="absolute -top-5 -left-5 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
      </div>
      <div>
        <span class="eyebrow">{home.privateEvents.eyebrow}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.5rem,5vw,4rem)] text-[var(--color-dark)] leading-tight mb-4">
          {home.privateEvents.titleLine1}<br />{home.privateEvents.titleLine2}
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-8 text-[1.0625rem]">
          {home.privateEvents.body}
        </p>
        <div class="mb-10">
          {PRIVATE_EVENT_TYPES.map((item) => (
            <div class="cm-event-item">
              <span class="cm-event-item-dot"></span>
              <span class="cm-event-item-label">{item.name}</span>
            </div>
          ))}
        </div>
        <a href="/private-events" class="btn-primary">{home.privateEvents.ctaLabel}</a>
      </div>
    </div>
  </section>

  <!-- ── STATS BAR ──────────────────────────────────────── -->
  <section class="bg-[var(--color-dark)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="cm-dark-grid" style="grid-template-columns: repeat(4, 1fr);">
        {home.stats.map((stat: any) => (
          <div class="cm-dark-grid-cell py-14">
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-teal-light)] text-3xl sm:text-4xl mb-2">
              {stat.number}<span class="text-2xl">{stat.unit}</span>
            </p>
            <p class="font-[family-name:var(--font-stamp)] text-white text-xs tracking-widest uppercase mb-1">{stat.label ?? fill(stat.labelTemplate, { street: SITE.address.street })}</p>
            <p class="font-[family-name:var(--font-body)] text-white/35 text-xs">{stat.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FIND US ─────────────────────────────────────────── -->
  <FindUs
    address={SITE.address.street}
    cityLine={`${SITE.address.neighborhood}, ${SITE.address.city}, ${SITE.address.state} ${SITE.address.zip}`}
    phone={SITE.phone.display}
    mapsHref={SITE.address.mapsUrl}
    openLine={`${todayHours} ${home.findUs.todaySuffix}`}
    accentLabel={home.findUs.accentLabel}
    accentValue={SITE.serviceMessaging.openDaily}
  />

  <Footer />
</BaseLayout>
