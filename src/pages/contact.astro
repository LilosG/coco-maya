---
import Picture from "../components/Picture.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { getSingleton } from "../lib/content";
import { breadcrumbSchema } from "../lib/schema";
const [SITE, page] = await Promise.all([getSingleton("siteSettings"), getSingleton("contactPage")]);
const fill = (value: string) => value.replaceAll("{{fullAddress}}", `${SITE.address.street}, ${SITE.address.city} ${SITE.address.state} ${SITE.address.zip}`).replaceAll("{{phone}}", SITE.phone.display).replaceAll("{{street}}", SITE.address.street);
const dayNames = SITE.weekdaysSundayFirst ?? [];
const todayName = dayNames[new Date().getDay()];
const schema = [
  breadcrumbSchema([
    { name: SITE.breadcrumbs.home, url: SITE.url },
    { name: page.breadcrumbLabel, url: `${SITE.url}/contact` },
  ]),
];
---
<BaseLayout
  title={fill(page.seo.title)}
  description={fill(page.seo.descriptionTemplate)}
  extraSchema={schema}
>
  <Nav />
  <section class="relative pt-44 pb-28 px-6 bg-[var(--color-cream)]">
    <div class="absolute inset-x-0 top-0 h-1 bg-[var(--color-teal)]"></div>
    <div class="max-w-5xl mx-auto">
      <div class="mb-14">
        <span class="eyebrow">{page.hero.label}</span>
        <h1 class="font-[family-name:var(--font-display)] italic text-[clamp(3rem,7vw,5.5rem)] text-[var(--color-dark)]">
          {page.hero.title}
          <span class="block font-[family-name:var(--font-stamp)] not-italic text-[clamp(0.85rem,1.8vw,1.15rem)] tracking-[0.08em] text-[var(--color-dark)]/55 mt-3">
            {fill(page.hero.titleSuffixTemplate)}
          </span>
        </h1>
      </div>
      <div class="grid md:grid-cols-2 gap-16 items-start">
        <div class="space-y-10">
          <div>
            <span class="eyebrow">{page.labels.address}</span>
            <a
              href={SITE.address.mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-2xl hover:text-[var(--color-teal)] transition-colors leading-snug block"
            >
              {SITE.address.street}<br />{SITE.address.neighborhood}<br />{SITE.address.city}, {SITE.address.state}
            </a>
          </div>
          <div>
            <span class="eyebrow">{page.labels.phone}</span>
            <a
              href={`tel:${SITE.phone.tel}`}
              class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-2xl hover:text-[var(--color-teal)] transition-colors"
            >
              {SITE.phone.display}
            </a>
          </div>
          <div>
            <span class="eyebrow">{page.labels.hours}</span>
            <div class="divide-y divide-[var(--color-teal)]/10">
              {(SITE.hours ?? []).map((h: any) => (
                <div class:list={[
                  "flex justify-between py-3.5 font-[family-name:var(--font-body)] text-sm",
                  h.day === todayName ? "text-[var(--color-dark)] font-medium" : "text-[var(--color-dark)]/40"
                ]}>
                  <span class:list={[h.day === todayName ? "text-[var(--color-teal)] font-semibold" : ""]}>{h.day}</span>
                  <span>{h.hours}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="flex flex-wrap gap-4 pt-2">
            <a href={SITE.address.mapsUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">{page.labels.directions}</a>
            <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-outline">{page.labels.reserve}</a>
          </div>
        </div>
        <div class="relative">
          <Picture
            src={page.image}
            alt={fill(page.imageAltTemplate)}
            class="w-full aspect-square object-cover"
            width="700" height="700"
            loading="lazy"
          />
          <div class="absolute -bottom-5 -right-5 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
          <div class="absolute bottom-6 left-6 right-6 bg-white/92 backdrop-blur-sm p-4 border-l-3 border-[var(--color-teal)]" style="border-left-width: 3px;">
            <span class="eyebrow mb-0.5">{page.labels.rooftop}</span>
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-lg">{SITE.serviceMessaging.openDaily}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <Footer />
</BaseLayout>
