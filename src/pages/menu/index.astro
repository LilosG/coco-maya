---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import CTASection from "../../components/CTASection.astro";
import PageHero from "../../components/PageHero.astro";
import { getOrderedCollection, getSingleton, resolveSiteTokens } from "../../lib/content";
import { breadcrumbSchema, menuSchema } from "../../lib/schema";
import Picture from "../../components/Picture.astro";
const [SITE, rawPage, FEATURED_COCKTAILS, FEATURED_FOOD, FEATURED_BRUNCH] = await Promise.all([getSingleton("siteSettings"), getSingleton("menuPage"), getOrderedCollection("menuCocktails"), getOrderedCollection("menuDinner"), getOrderedCollection("menuBrunchFood")]);
const page = resolveSiteTokens(rawPage, SITE);
const schema = [
  breadcrumbSchema([
    { name: SITE.breadcrumbs.home, url: SITE.url },
    { name: page.breadcrumbLabel, url: `${SITE.url}/menu` },
  ]),
  menuSchema(
    [
      { name: page.sections.cocktails.title, items: FEATURED_COCKTAILS },
      { name: page.sections.food.title, items: FEATURED_FOOD },
      { name: page.sections.brunch.title, items: FEATURED_BRUNCH },
    ],
    SITE.url
  ),
];
---
<BaseLayout
  title={page.seo.title}
  description={page.seo.description}
  image={page.seo.image}
  extraSchema={schema}
>
  <Nav />
  <PageHero
    label={page.hero.label}
    title={page.hero.title}
    titleSuffix={page.hero.titleSuffix}
    subtitle={page.hero.subtitle}
    image={page.hero.image}
    imageAlt={page.hero.imageAlt}
    tall={false}
  />

  <div class="sticky top-0 z-30 bg-[var(--color-cream)]/97 backdrop-blur-md border-b border-[var(--color-teal)]/12 shadow-sm">
    <div class="max-w-7xl mx-auto px-6 flex gap-8 overflow-x-auto py-4">
      {Object.values(page.sections ?? {}).map((section: any) => (
        <a
          href={"#" + section.id}
          class="font-[family-name:var(--font-stamp)] text-xs tracking-widest uppercase text-[var(--color-dark)]/50 hover:text-[var(--color-teal)] transition-colors whitespace-nowrap"
        >
          {section.navLabel}
        </a>
      ))}
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-20 space-y-24 bg-[var(--color-cream)]">

    <section id="cocktails">
      <span class="eyebrow">{page.sections.cocktails.eyebrow}</span>
      <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-10">{page.sections.cocktails.title}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {FEATURED_COCKTAILS.map((drink) => (
          <div class="cm-media-card group">
            <div class="aspect-square overflow-hidden">
<Picture src={drink.image} alt={drink.name} class="w-full h-full object-cover" width="300" height="300" loading="lazy" decoding="async" />
            </div>
            <div class="p-5 border-t border-[var(--color-teal)]/12">
              <h3 class="font-[family-name:var(--font-stamp)] text-[var(--color-dark)] text-sm tracking-wide mb-1.5">{drink.name}</h3>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/45 text-xs leading-relaxed">{drink.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="food">
      <span class="eyebrow">{page.sections.food.eyebrow}</span>
      <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-10">{page.sections.food.title}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {FEATURED_FOOD.map((item) => (
          <div class="cm-media-card group">
            <div class="aspect-square overflow-hidden">
<Picture src={item.image} alt={item.name} class="w-full h-full object-cover" width="300" height="300" loading="lazy" decoding="async" />
            </div>
            <div class="p-5 border-t border-[var(--color-teal)]/12">
              <h3 class="font-[family-name:var(--font-stamp)] text-[var(--color-dark)] text-sm tracking-wide mb-1.5">{item.name}</h3>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/45 text-xs leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="brunch">
      <span class="eyebrow">{page.sections.brunch.eyebrow}</span>
      <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-2">{page.sections.brunch.title}</h2>
      <p class="font-[family-name:var(--font-stamp)] text-[var(--color-teal)] text-xs tracking-widest uppercase mb-10">{SITE.service.brunch.tagline}</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {FEATURED_BRUNCH.map((item) => (
          <div class="cm-media-card group">
            <div class="aspect-square overflow-hidden">
              <Picture src={item.image} alt={item.name} class="w-full h-full object-cover" width="300" height="300" loading="lazy" decoding="async" />
            </div>
            <div class="p-5 border-t border-[var(--color-teal)]/12">
              <h3 class="font-[family-name:var(--font-stamp)] text-[var(--color-dark)] text-sm tracking-wide mb-1.5">{item.name}</h3>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/45 text-xs leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>

  <CTASection
    title={page.cta.title}
    subtitle={page.cta.subtitle}
    primaryLabel={page.cta.primaryLabel}
    primaryHref={SITE.reservations.url}
    secondaryLabel={page.cta.secondaryLabel}
    secondaryHref={SITE.order.url}
    dark={true}
  />
  <Footer />
</BaseLayout>
