---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import CTASection from "../../components/CTASection.astro";
import PageHero from "../../components/PageHero.astro";
import { SITE } from "../../data/site";
import { FEATURED_COCKTAILS, FEATURED_FOOD, FEATURED_BRUNCH } from "../../data/menu";
import { breadcrumbSchema, menuSchema } from "../../lib/schema";
const schema = [
  breadcrumbSchema([
    { name: "Home", url: SITE.url },
    { name: "Menu", url: `${SITE.url}/menu` },
  ]),
  menuSchema(
    [
      { name: "Cocktails", items: FEATURED_COCKTAILS },
      { name: "Food", items: FEATURED_FOOD },
      { name: "Brunch", items: FEATURED_BRUNCH },
    ],
    SITE.url
  ),
];
---
<BaseLayout
  title="Menu | Coco Maya by Miss Bs | Little Italy San Diego"
  description="Full menu at Coco Maya in Little Italy San Diego. Modern American coastal cuisine, craft cocktails, and brunch served daily. 1660 India St."
  image="/images/food-spread-overhead.jpg"
  extraSchema={schema}
>
  <Nav />
  <PageHero
    label="Modern Coastal Cuisine"
    title="The Menu"
    titleSuffix="Modern Coastal Cuisine in Little Italy, San Diego"
    subtitle="Modern coastal plates, craft cocktails, and brunch served daily."
    image="/images/food-menu-hero.jpg"
    imageAlt="Full spread of Coco Maya dishes on the patio at Little Italy San Diego"
    tall={false}
  />

  <div class="sticky top-0 z-30 bg-[var(--color-cream)]/97 backdrop-blur-md border-b border-[var(--color-teal)]/12 shadow-sm">
    <div class="max-w-7xl mx-auto px-6 flex gap-8 overflow-x-auto py-4">
      {[["cocktails","Cocktails"],["food","Food"],["brunch","Brunch"]].map(([id, label]) => (
        <a
          href={"#" + id}
          class="font-[family-name:var(--font-stamp)] text-xs tracking-widest uppercase text-[var(--color-dark)]/50 hover:text-[var(--color-teal)] transition-colors whitespace-nowrap"
        >
          {label}
        </a>
      ))}
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-20 space-y-24 bg-[var(--color-cream)]">

    <section id="cocktails">
      <span class="eyebrow">Craft Program</span>
      <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-10">Cocktails</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {FEATURED_COCKTAILS.map((drink) => (
          <div class="cm-media-card group">
            <div class="aspect-square overflow-hidden">
              <picture>
                <source srcset={drink.image.replace(/\.(jpg|jpeg|png)$/i, ".webp")} type="image/webp" />
                <img src={drink.image} alt={drink.name} class="w-full h-full object-cover" width="300" height="300" loading="lazy" decoding="async" />
              </picture>
            </div>
            <div class="p-5 border-t border-[var(--color-teal)]/12">
              <h3 class="font-[family-name:var(--font-stamp)] text-[var(--color-dark)] text-sm tracking-wide mb-1.5">{drink.name}</h3>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/45 text-xs leading-relaxed">{drink.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="food">
      <span class="eyebrow">The Kitchen</span>
      <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-10">Food</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {FEATURED_FOOD.map((item) => (
          <div class="cm-media-card group">
            <div class="aspect-square overflow-hidden">
              <picture>
                <source srcset={item.image.replace(/\.(jpg|jpeg|png)$/i, ".webp")} type="image/webp" />
                <img src={item.image} alt={item.name} class="w-full h-full object-cover" width="300" height="300" loading="lazy" decoding="async" />
              </picture>
            </div>
            <div class="p-5 border-t border-[var(--color-teal)]/12">
              <h3 class="font-[family-name:var(--font-stamp)] text-[var(--color-dark)] text-sm tracking-wide mb-1.5">{item.name}</h3>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/45 text-xs leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="brunch">
      <span class="eyebrow">Served Daily</span>
      <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-2">Brunch</h2>
      <p class="font-[family-name:var(--font-stamp)] text-[var(--color-teal)] text-xs tracking-widest uppercase mb-10">{SITE.service.brunch.tagline}</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {FEATURED_BRUNCH.map((item) => (
          <div class="cm-media-card group">
            <div class="aspect-square overflow-hidden">
              <img src={item.image} alt={item.name} class="w-full h-full object-cover" width="300" height="300" loading="lazy" />
            </div>
            <div class="p-5 border-t border-[var(--color-teal)]/12">
              <h3 class="font-[family-name:var(--font-stamp)] text-[var(--color-dark)] text-sm tracking-wide mb-1.5">{item.name}</h3>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/45 text-xs leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

  </div>

  <CTASection
    title="Ready to Dine?"
    subtitle="Reserve your table at Coco Maya in Little Italy."
    primaryLabel="Reserve a Table"
    primaryHref={SITE.reservations.url}
    secondaryLabel="Order Online"
    secondaryHref={SITE.order.url}
    dark={true}
  />
  <Footer />
</BaseLayout>
