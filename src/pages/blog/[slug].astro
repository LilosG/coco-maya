---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import CTASection from "../../components/CTASection.astro";
import EventInquiryForm from "../../components/EventInquiryForm.astro";
import { SITE } from "../../data/site";
import { breadcrumbSchema } from "../../lib/schema";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const cta = post.data.eventCTA;

const publishedISO = post.data.date.toISOString();
// dateModified reflects updatedDate when a post has actually been edited.
// Falls back to the publish date for posts that have never been updated.
const modifiedISO = (post.data.updatedDate ?? post.data.date).toISOString();

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    image: `${SITE.url}${post.data.image}`,
    datePublished: publishedISO,
    dateModified: modifiedISO,
    author: {
      "@type": "Organization",
      name: SITE.fullName,
    },
    publisher: {
      "@type": "Organization",
      name: SITE.fullName,
    },
    mainEntityOfPage: `${SITE.url}/blog/${post.id}`,
  },
  breadcrumbSchema([
    { name: "Home", url: SITE.url },
    { name: "Blog", url: `${SITE.url}/blog` },
    { name: post.data.title, url: `${SITE.url}/blog/${post.id}` },
  ]),
];

const formattedDate = post.data.date.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---
<BaseLayout
  title={post.data.seoTitle}
  description={post.data.description}
  image={post.data.image}
  extraSchema={schema}
  type="article"
  publishedTime={publishedISO}
  modifiedTime={modifiedISO}
>
  <Nav />

  <PageHero
    label={formattedDate}
    title={post.data.title}
    image={post.data.image}
    imageAlt={post.data.imageAlt}
  />

  <article class="py-20 px-6 bg-[var(--color-cream)]">
    <div class="max-w-2xl mx-auto blog-content">
      <Content />
    </div>
  </article>

  {cta && (
    <EventInquiryForm
      label={cta.formLabel}
      subtitle={cta.formSubtitle ?? "Share your date, headcount, and vision, and we'll follow up within 24 hours."}
    />
  )}

  <CTASection
    title={cta?.title ?? "Ready to Visit?"}
    subtitle={cta?.subtitle ?? "Reserve your table at Coco Maya in Little Italy."}
    primaryLabel={cta?.primaryLabel ?? "Reserve a Table"}
    primaryHref={cta?.primaryHref ?? SITE.reservations.url}
    secondaryLabel={cta?.secondaryLabel}
    secondaryHref={cta?.secondaryHref}
    dark={true}
  />
  <Footer />
</BaseLayout>

<style>
  .blog-content {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: rgba(23, 20, 16, 0.72);
  }
  .blog-content :global(h2) {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    color: var(--color-dark);
    margin-top: 2.75rem;
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }
  .blog-content :global(p) {
    margin-bottom: 1.5rem;
  }
  .blog-content :global(ul) {
    margin: 1.5rem 0 2rem;
    padding-left: 0;
    list-style: none;
  }
  .blog-content :global(ol) {
    margin: 1.5rem 0 2rem;
    padding-left: 1.25rem;
  }
  .blog-content :global(li) {
    margin-bottom: 0.875rem;
    padding-left: 1.5rem;
    position: relative;
  }
  .blog-content :global(ul li::before) {
    content: "";
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 50%;
    background-color: var(--color-teal);
  }
  .blog-content :global(strong) {
    color: var(--color-dark);
    font-weight: 600;
  }
  .blog-content :global(a) {
    color: var(--color-teal);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .blog-content :global(a:hover) {
    color: var(--color-teal-dark);
  }
</style>
