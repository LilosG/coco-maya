---
import Picture from "../../components/Picture.astro";
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import { getSingleton } from "../../lib/content";

const [allPosts, page] = await Promise.all([getCollection("blog"), getSingleton("blogIndexPage")]);
const posts = allPosts
  .map((post) => ({
    slug: post.id,
    title: post.data.title,
    excerpt: post.data.description,
    date: post.data.date,
    image: post.data.image,
  }))
  .sort((a, b) => b.date.valueOf() - a.date.valueOf());
---
<BaseLayout title={page.seo.title} description={page.seo.description}>
  <Nav />
  <PageHero label={page.hero.label} title={page.hero.title} titleSuffix={page.hero.titleSuffix} subtitle={page.hero.subtitle} />

  <section class="py-16 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
      {posts.map((post, i) => (
        <a href={`/blog/${post.slug}`}
          class:list={["group block border border-[var(--color-teal)]/10 hover:border-[var(--color-teal)]/40 transition-colors overflow-hidden", i === 0 ? "md:col-span-2" : ""]}>
          <div class:list={["overflow-hidden", i === 0 ? "aspect-[21/9]" : "aspect-video"]}>
            <Picture src={post.image} alt={post.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              width={i === 0 ? 1200 : 600} height={i === 0 ? 514 : 338}
              loading={i === 0 ? "eager" : "lazy"} />
          </div>
          <div class="p-6">
            <p class="font-[family-name:var(--font-stamp)] text-[var(--color-teal)] text-xs tracking-widest uppercase mb-2">
              {new Date(post.date).toLocaleDateString("en-US", { month: "long", year: "numeric" })}
            </p>
            <h2 class:list={["font-[family-name:var(--font-display)] text-[var(--color-dark)] italic group-hover:text-[var(--color-teal)] transition-colors mb-3", i === 0 ? "text-3xl" : "text-xl"]}>
              {post.title}
            </h2>
            <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)] opacity-50 text-sm leading-relaxed">{post.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
  <Footer />
</BaseLayout>
