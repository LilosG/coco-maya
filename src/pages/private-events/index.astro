---
import Picture from "../../components/Picture.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import CTASection from "../../components/CTASection.astro";
import InfoCard from "../../components/InfoCard.astro";
import EventInquiryForm from "../../components/EventInquiryForm.astro";
import { getOrderedCollection, getSingleton, resolveSiteTokens } from "../../lib/content";
import { breadcrumbSchema } from "../../lib/schema";

const [SITE, rawPage, rawPrivateEventTypes, process, specs] = await Promise.all([getSingleton("siteSettings"), getSingleton("privateEventsIndexPage"), getOrderedCollection("privateEventTypes"), getOrderedCollection("privateEventsProcessSteps"), getOrderedCollection("privateEventsCapacitySpecs")]);
const page = resolveSiteTokens(rawPage, SITE);
const PRIVATE_EVENT_TYPES = resolveSiteTokens(rawPrivateEventTypes, SITE);
const schema = [
  breadcrumbSchema([
    { name: SITE.breadcrumbs.home, url: SITE.url },
    { name: page.breadcrumbLabel, url: `${SITE.url}/private-events` },
  ]),
];
---
<BaseLayout
  title={page.seo.title}
  description={page.seo.description}
  image={page.seo.image}
  extraSchema={schema}
>
  <Nav />

  <PageHero
    label={page.hero.label}
    title={page.hero.title}
    titleSuffix={page.hero.titleSuffix}
    subtitle={page.hero.subtitle}
    image={page.hero.image}
    imageAlt={page.hero.imageAlt}
    tall={true}
  >
    <div class="flex flex-wrap gap-4 mt-8">
      <a href={`mailto:${SITE.email}?subject=Private Event Inquiry`} class="btn-primary">{page.hero.primaryLabel}</a>
      <a href={`tel:${SITE.phone.tel}`} class="btn-ghost">{SITE.phone.display}</a>
    </div>
  </PageHero>

  <!-- CAPACITY CARDS -->
  <section class="py-16 px-6 bg-[var(--color-cream)]">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-5">
      {specs.map((s, i) => (
        <InfoCard label={s.label} value={s.value} sub={s.note} accent={i === 1} />
      ))}
    </div>
  </section>

  <div class="cm-divider"></div>

  <!-- FEATURED SPACE IMAGE + STATEMENT -->
  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="eyebrow">{page.intro.eyebrow}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.25rem,4vw,3.5rem)] text-[var(--color-dark)] leading-tight mb-6">
          {page.intro.title}
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-5">
          {page.intro.body1}
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-10">
          {page.intro.body2}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href={`mailto:${SITE.email}?subject=Private Event Inquiry`} class="btn-primary">{page.intro.emailLabel}</a>
          <a href="/the-space" class="btn-outline">{page.intro.spaceLabel}</a>
        </div>
      </div>
      <div class="relative">
        <Picture
          src={page.intro.image}
          alt={page.intro.imageAlt}
          class="w-full aspect-[4/5] object-cover"
          width="700" height="875" loading="lazy"
        />
        <div class="absolute -bottom-4 -right-4 w-full h-full border border-[var(--color-teal)]/20 -z-10 pointer-events-none"></div>
      </div>
    </div>
  </section>

  <!-- EVENT TYPES GRID -->
  <section class="py-24 px-6 bg-[var(--color-sand-dark)]/25">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-2xl mb-14">
        <span class="eyebrow">{page.types.eyebrow}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] leading-tight">
          {page.types.title}
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {PRIVATE_EVENT_TYPES.map((event) => (
          <a href={`/private-events/${event.slug}`} class="cm-media-card group block">
            <div class="aspect-video overflow-hidden">
              <Picture
                src={event.heroImage}
                alt={event.heroImageAlt}
                class="w-full h-full object-cover"
                width="600" height="338" loading="lazy"
              />
            </div>
            <div class="p-6">
              <h3 class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-xl mb-2 group-hover:text-[var(--color-teal)] transition-colors">{event.name}</h3>
              <div class="w-6 h-px bg-[var(--color-teal)] mb-3"></div>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/50 text-sm leading-relaxed">{event.shortDescription}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <span class="eyebrow">{page.process.eyebrow}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3rem)] text-[var(--color-dark)]">{page.process.title}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {process.map((step) => (
          <div class="relative">
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-teal)]/20 text-[5rem] leading-none mb-4 select-none">{step.step}</p>
            <span class="eyebrow">{step.label}</span>
            <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/60 text-sm leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FULL BLEED NIGHT EVENT IMAGE -->
  <section class="relative h-[55vh] overflow-hidden">
    <Picture
      src={page.atmosphere.image}
      alt={page.atmosphere.imageAlt}
      class="w-full h-full object-cover object-center"
      width="1800" height="900" loading="lazy"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.35) 60%, rgba(0,0,0,0.1) 100%);"></div>
    <div class="absolute inset-0 flex items-center px-8 md:px-20">
      <div class="max-w-lg">
        <span class="eyebrow-light">{page.atmosphere.eyebrow}</span>
        <p class="font-[family-name:var(--font-display)] italic text-white text-[clamp(2rem,4vw,3.25rem)] leading-tight mb-8">
          {page.atmosphere.line}
        </p>
        <a href={`mailto:${SITE.email}?subject=Private Event Inquiry`} class="btn-white">{page.atmosphere.ctaLabel}</a>
      </div>
    </div>
  </section>

  <!-- EVENT SPECS DARK GRID -->
  <section class="bg-[var(--color-dark)] px-6 py-20">
    <div class="max-w-4xl mx-auto">
      <span class="eyebrow-light mx-auto block text-center mb-10">{page.capacityHeading}</span>
      <div class="cm-dark-grid" style="grid-template-columns: repeat(3, 1fr);">
        {specs.map((item) => (
          <div class="cm-dark-grid-cell">
            <span class="eyebrow-light mb-4">{item.label}</span>
            <p class="font-[family-name:var(--font-display)] italic text-white text-3xl mb-2">{item.value}</p>
            <p class="font-[family-name:var(--font-body)] text-white/35 text-sm">{item.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INQUIRY SECTION -->
  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <span class="eyebrow">{page.inquiry.eyebrow}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.25rem)] text-[var(--color-dark)] leading-tight mb-6">
          {page.inquiry.title}
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-8">
          {page.inquiry.body}
        </p>
        <div class="space-y-5">{(page.inquiry.sellingPoints ?? []).map((item: string) => <div class="cm-event-item"><div class="cm-event-item-dot"></div><span class="cm-event-item-label">{item}</span></div>)}</div>
      </div>
      <div class="space-y-5">
        <div class="cc-card">
          <div class="cc-card__bar"></div>
          <div class="cc-card__body">
            <span class="cc-card__label">{page.inquiry.emailCard.label}</span>
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-2xl mb-2">{page.inquiry.emailCard.title}</p>
            <p class="cc-card__text">{page.inquiry.emailCard.body}</p>
            <a href={`mailto:${SITE.email}?subject=Private Event Inquiry at Coco Maya`} class="btn-primary mt-6 self-start">
              {SITE.email}
            </a>
          </div>
        </div>
        <div class="cc-card">
          <div class="cc-card__bar"></div>
          <div class="cc-card__body">
            <span class="cc-card__label">{page.inquiry.phoneCard.label}</span>
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-2xl mb-2">{page.inquiry.phoneCard.title}</p>
            <p class="cc-card__text">{page.inquiry.phoneCard.body}</p>
            <a href={`tel:${SITE.phone.tel}`} class="btn-outline mt-6 self-start">{SITE.phone.display}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <EventInquiryForm
    label={page.form.label}
    subtitle={page.form.subtitle}
    formUrl={SITE.inquiryForm.url}
    ctaLabel={page.form.ctaLabel}
  />

  <CTASection
    title={page.cta.title}
    subtitle={page.cta.subtitle}
    primaryLabel={page.cta.primaryLabel}
    primaryHref={`mailto:${SITE.email}?subject=Private Event Inquiry`}
    secondaryLabel={SITE.phone.display}
    secondaryHref={`tel:${SITE.phone.tel}`}
    dark={true}
  />
  <Footer />
</BaseLayout>
