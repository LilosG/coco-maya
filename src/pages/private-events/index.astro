---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import CTASection from "../../components/CTASection.astro";
import InfoCard from "../../components/InfoCard.astro";
import EventInquiryForm from "../../components/EventInquiryForm.astro";
import { SITE } from "../../data/site";
import { PRIVATE_EVENT_TYPES } from "../../data/privateEvents";

const process = [
  { step: "01", label: "Get in Touch", body: "Email or call us with your date, group size, and what you have in mind. We will respond within 24 hours." },
  { step: "02", label: "Custom Proposal", body: "We put together a package tailored to your event — menu, space configuration, drinks, and pricing." },
  { step: "03", label: "Confirm and Deposit", body: "Review the proposal, sign the agreement, and secure your date with a deposit." },
  { step: "04", label: "Your Event", body: "Show up. We handle everything else. Our team runs the event so you can actually enjoy it." },
];

const specs = [
  { label: "Indoor Capacity",  value: "Up to 60",     note: "Private dining room" },
  { label: "Patio Capacity",   value: "Up to 120",    note: "Full patio buyout" },
  { label: "Full Venue",       value: "Up to 180",    note: "Indoor + patio combined" },
];
---
<BaseLayout
  title="Private Event Venue Little Italy San Diego | Bachelorette & Birthday | Coco Maya"
  description="San Diego's top private event venue in Little Italy. Bachelorette parties, birthday dinners, rehearsal dinners & corporate events at Coco Maya rooftop. 1660 India St, 92101."
  image="/images/events-private-dining-1.jpg"
>
  <Nav />

  <PageHero
    label="Group Bookings"
    title="Private Events in San Diego"
    subtitle="Coco Maya provides a private event space in Little Italy that your guests will actually talk about."
    image="/images/events-private-dining-1.jpg"
    imageAlt="Private event dining at Coco Maya Little Italy San Diego"
    tall={true}
  >
    <div class="flex flex-wrap gap-4 mt-8">
      <a href={`mailto:${SITE.email}?subject=Private Event Inquiry`} class="btn-primary">Start Planning</a>
      <a href={`tel:${SITE.phone.tel}`} class="btn-ghost">{SITE.phone.display}</a>
    </div>
  </PageHero>

  <!-- CAPACITY CARDS -->
  <section class="py-16 px-6 bg-[var(--color-cream)]">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-5">
      {specs.map((s, i) => (
        <InfoCard label={s.label} value={s.value} sub={s.note} accent={i === 1} />
      ))}
    </div>
  </section>

  <div class="cm-divider"></div>

  <!-- FEATURED SPACE IMAGE + STATEMENT -->
  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="eyebrow">Rooftop Event Venue · Little Italy San Diego</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.25rem,4vw,3.5rem)] text-[var(--color-dark)] leading-tight mb-6">
          Private Event Venue in Little Italy San Diego
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-5">
          Coco Maya is one of San Diego most distinctive venues. The glass atrium bar, the elevated outdoor patio, the tropical mural dining room — each space has its own character and can be configured for groups of any size.
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-10">
          We work with you on custom menus, drink packages, decor, and anything else that makes your event feel like yours. Little Italy provides the backdrop. We handle the rest.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href={`mailto:${SITE.email}?subject=Private Event Inquiry`} class="btn-primary">Email Us</a>
          <a href="/the-space" class="btn-outline">See The Space</a>
        </div>
      </div>
      <div class="relative">
        <img
          src="/images/events-private-dining-2.jpg"
          alt="Private event dining room at Coco Maya — rooftop venue Little Italy San Diego"
          class="w-full aspect-[4/5] object-cover"
          width="700" height="875" loading="lazy"
        />
        <div class="absolute -bottom-4 -right-4 w-full h-full border border-[var(--color-teal)]/20 -z-10 pointer-events-none"></div>
      </div>
    </div>
  </section>

  <!-- EVENT TYPES GRID -->
  <section class="py-24 px-6 bg-[var(--color-sand-dark)]/25">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-2xl mb-14">
        <span class="eyebrow">Bachelorette Parties · Birthdays · Corporate Events</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] leading-tight">
          Every occasion deserves a space worth remembering.
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {PRIVATE_EVENT_TYPES.map((event) => (
          <a href={`/private-events/${event.slug}`} class="cm-media-card group block">
            <div class="aspect-video overflow-hidden">
              <img
                src={event.heroImage}
                alt={event.heroImageAlt}
                class="w-full h-full object-cover"
                width="600" height="338" loading="lazy"
              />
            </div>
            <div class="p-6">
              <h3 class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-xl mb-2 group-hover:text-[var(--color-teal)] transition-colors">{event.name}</h3>
              <div class="w-6 h-px bg-[var(--color-teal)] mb-3"></div>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/50 text-sm leading-relaxed">{event.shortDescription}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <span class="eyebrow">How It Works</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3rem)] text-[var(--color-dark)]">From first inquiry to your event</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {process.map((step) => (
          <div class="relative">
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-teal)]/20 text-[5rem] leading-none mb-4 select-none">{step.step}</p>
            <span class="eyebrow">{step.label}</span>
            <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/60 text-sm leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FULL BLEED NIGHT EVENT IMAGE -->
  <section class="relative h-[55vh] overflow-hidden">
    <img
      src="/images/events-private-patio-day.jpg"
      alt="Rooftop patio at Coco Maya — private event venue in Little Italy San Diego"
      class="w-full h-full object-cover object-center"
      width="1800" height="900" loading="lazy"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.35) 60%, rgba(0,0,0,0.1) 100%);"></div>
    <div class="absolute inset-0 flex items-center px-8 md:px-20">
      <div class="max-w-lg">
        <span class="eyebrow-light">The Patio After Dark</span>
        <p class="font-[family-name:var(--font-display)] italic text-white text-[clamp(2rem,4vw,3.25rem)] leading-tight mb-8">
          Little Italy as your backdrop. Every single night.
        </p>
        <a href={`mailto:${SITE.email}?subject=Private Event Inquiry`} class="btn-white">Start Planning Your Event</a>
      </div>
    </div>
  </section>

  <!-- EVENT SPECS DARK GRID -->
  <section class="bg-[var(--color-dark)] px-6 py-20">
    <div class="max-w-4xl mx-auto">
      <span class="eyebrow-light mx-auto block text-center mb-10">Capacity and Spaces</span>
      <div class="cm-dark-grid" style="grid-template-columns: repeat(3, 1fr);">
        {specs.map((item) => (
          <div class="cm-dark-grid-cell">
            <span class="eyebrow-light mb-4">{item.label}</span>
            <p class="font-[family-name:var(--font-display)] italic text-white text-3xl mb-2">{item.value}</p>
            <p class="font-[family-name:var(--font-body)] text-white/35 text-sm">{item.note}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INQUIRY SECTION -->
  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <span class="eyebrow">Get in Touch</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.25rem)] text-[var(--color-dark)] leading-tight mb-6">
          Tell us about your event
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-8">
          Email us with your date, expected headcount, and the type of event. We will put together a custom proposal within 24 hours.
        </p>
        <div class="space-y-5">
          <div class="cm-event-item">
            <div class="cm-event-item-dot"></div>
            <span class="cm-event-item-label">Events from 20 to 180 guests</span>
          </div>
          <div class="cm-event-item">
            <div class="cm-event-item-dot"></div>
            <span class="cm-event-item-label">Custom menus and drink packages</span>
          </div>
          <div class="cm-event-item">
            <div class="cm-event-item-dot"></div>
            <span class="cm-event-item-label">Indoor, patio, or full venue options</span>
          </div>
          <div class="cm-event-item">
            <div class="cm-event-item-dot"></div>
            <span class="cm-event-item-label">Dedicated event coordinator</span>
          </div>
          <div class="cm-event-item">
            <div class="cm-event-item-dot"></div>
            <span class="cm-event-item-label">AV, decor, and vendor coordination available</span>
          </div>
        </div>
      </div>
      <div class="space-y-5">
        <div class="cc-card">
          <div class="cc-card__bar"></div>
          <div class="cc-card__body">
            <span class="cc-card__label">Email Us</span>
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-2xl mb-2">Start the conversation</p>
            <p class="cc-card__text">Send us your event details and we will respond within 24 hours with availability and initial pricing.</p>
            <a href={`mailto:${SITE.email}?subject=Private Event Inquiry at Coco Maya`} class="btn-primary mt-6 self-start">
              {SITE.email}
            </a>
          </div>
        </div>
        <div class="cc-card">
          <div class="cc-card__bar"></div>
          <div class="cc-card__body">
            <span class="cc-card__label">Call Us</span>
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-2xl mb-2">Talk to someone now</p>
            <p class="cc-card__text">Prefer to talk through the details? Call us directly during business hours and we will get you sorted.</p>
            <a href={`tel:${SITE.phone.tel}`} class="btn-outline mt-6 self-start">{SITE.phone.display}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <EventInquiryForm
    label="Or Send Us Your Details"
    subtitle="Prefer to send details directly? Share your date, headcount, and event type and we'll follow up within 24 hours."
  />

  <CTASection
    title="Ready to Start Planning?"
    subtitle="Tell us what you have in mind. We will put together a package that works for your group."
    primaryLabel="Email Us"
    primaryHref={`mailto:${SITE.email}?subject=Private Event Inquiry`}
    secondaryLabel={SITE.phone.display}
    secondaryHref={`tel:${SITE.phone.tel}`}
    dark={true}
  />
  <Footer />
</BaseLayout>
