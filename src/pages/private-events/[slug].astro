---
import Picture from "../../components/Picture.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import CTASection from "../../components/CTASection.astro";
import FAQSection from "../../components/FAQSection.astro";
import EventInquiryForm from "../../components/EventInquiryForm.astro";
import InfoCard from "../../components/InfoCard.astro";
import ContentCard from "../../components/ContentCard.astro";
import { getOrderedCollection, getSingleton, resolveSiteTokens } from "../../lib/content";
import { faqPageSchema, breadcrumbSchema } from "../../lib/schema";

export async function getStaticPaths() {
  const SITE = await getSingleton("siteSettings");
  const PRIVATE_EVENT_TYPES = resolveSiteTokens(await getOrderedCollection("privateEventTypes"), SITE);
  return PRIVATE_EVENT_TYPES.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const [SITE, defaults] = await Promise.all([getSingleton("siteSettings"), getSingleton("privateEventDetailDefaults")]);
const fill = (value: string) => value.replaceAll("{{eventName}}", event.name).replaceAll("{{eventNameLower}}", event.name.toLowerCase());
const schema = [
  faqPageSchema(event.faqs ?? []),
  breadcrumbSchema([
    { name: SITE.breadcrumbs.home, url: SITE.url },
    { name: defaults.breadcrumbParentLabel, url: `${SITE.url}/private-events` },
    { name: event.name, url: `${SITE.url}/private-events/${event.slug}` },
  ]),
];
const mailtoHref = `mailto:${SITE.email}?subject=${encodeURIComponent(`${event.name} Inquiry`)}`;
---
<BaseLayout
  title={event.seoTitle}
  description={event.seoDescription}
  image={event.heroImage}
  extraSchema={schema}
>
  <Nav />

  <PageHero
    label={event.eyebrow}
    title={event.name}
    titleSuffix={defaults.heroTitleSuffix}
    subtitle={event.shortDescription}
    image={event.heroImage}
    imageAlt={event.heroImageAlt}
  >
    <div class="flex flex-wrap gap-4 mt-8">
      <a href={mailtoHref} class="btn-primary">{defaults.labels.startPlanning}</a>
      <a href={`tel:${SITE.phone.tel}`} class="btn-ghost">{SITE.phone.display}</a>
    </div>
  </PageHero>

  <!-- SPECS -->
  <section class="py-16 px-6 bg-[var(--color-cream)]">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-5">
      <InfoCard label={defaults.labels.guests} value={event.specs.guests} accent={true} />
      <InfoCard label={defaults.labels.duration} value={event.specs.duration} />
      <InfoCard label={defaults.labels.space} value={event.specs.space} />
    </div>
  </section>

  <div class="cm-divider"></div>

  <!-- INTRO + GALLERY IMAGE -->
  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="eyebrow">{defaults.labels.location}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.25rem,4vw,3.5rem)] text-[var(--color-dark)] leading-tight mb-6">
          {event.name} at Coco Maya
        </h2>
        <div class="rule"></div>
        {(event.intro ?? []).map((paragraph: string) => (
          <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-5">
            {paragraph}
          </p>
        ))}
        <div class="flex flex-wrap gap-4 mt-4">
          <a href={mailtoHref} class="btn-primary">{defaults.labels.email}</a>
          <a href="/private-events" class="btn-outline">{defaults.labels.allEvents}</a>
          {event.relatedPost && (
            <a href={event.relatedPost.href} class="btn-outline">{event.relatedPost.label}</a>
          )}
        </div>
      </div>
      <div class="relative">
        <Picture
          src={event.galleryImage}
          alt={event.galleryImageAlt}
          class="w-full aspect-[4/5] object-cover"
          width="700" height="875" loading="lazy"
        />
        <div class="absolute -bottom-4 -right-4 w-full h-full border border-[var(--color-teal)]/20 -z-10 pointer-events-none"></div>
      </div>
    </div>
  </section>

  <!-- GALLERY GRID -->
  <section class="py-20 px-6 bg-[var(--color-sand-dark)]/20">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <span class="eyebrow">{defaults.labels.setting}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3rem)] text-[var(--color-dark)]">
          {defaults.labels.closerLook}
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {(event.gallery ?? []).map((item: any) => (
          <div class="cm-media-card group">
            <div class="aspect-[4/5] overflow-hidden">
              <Picture
                src={item.image}
                alt={item.alt}
                class="w-full h-full object-cover"
                width="500" height="625" loading="lazy"
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HIGHLIGHTS -->
  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <span class="eyebrow">{defaults.labels.included}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3rem)] text-[var(--color-dark)]">
          {fill(defaults.builtForTemplate)}
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {(event.highlights ?? []).map((item: any) => (
          <ContentCard label={item.label} body={item.detail} />
        ))}
      </div>
    </div>
  </section>

  <!-- ATMOSPHERE BREAK -->
  <section class="relative h-[55vh] overflow-hidden">
    <Picture
      src={event.atmosphereImage}
      alt={event.atmosphereImageAlt}
      class="w-full h-full object-cover object-center"
      width="1800" height="900" loading="lazy"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 60%, rgba(0,0,0,0.1) 100%);"></div>
    <div class="absolute inset-0 flex items-center px-8 md:px-20">
      <div class="max-w-lg">
        <span class="eyebrow-light">{event.eyebrow}</span>
        <p class="font-[family-name:var(--font-display)] italic text-white text-[clamp(1.75rem,4vw,3rem)] leading-tight">
          {event.atmosphereLine}
        </p>
      </div>
    </div>
  </section>

  <FAQSection faqs={event.faqs} label={defaults.labels.questions} title={fill(defaults.faqTitleTemplate)} />

  <EventInquiryForm
    label={fill(defaults.formLabelTemplate)}
    subtitle={defaults.formSubtitle}
    formUrl={SITE.inquiryForm.url}
    ctaLabel={defaults.formCtaLabel}
  />

  <CTASection
    title={defaults.cta.title}
    subtitle={fill(defaults.cta.subtitleTemplate)}
    primaryLabel={defaults.cta.primaryLabel}
    primaryHref={mailtoHref}
    secondaryLabel={SITE.phone.display}
    secondaryHref={`tel:${SITE.phone.tel}`}
    dark={true}
  />
  <Footer />
</BaseLayout>
