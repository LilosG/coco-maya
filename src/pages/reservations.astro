---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { SITE } from "../data/site";
const dayNames = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
const todayName = dayNames[new Date().getDay()];
---
<BaseLayout
  title="Reservations | Coco Maya | Little Italy San Diego"
  description={`Reserve a table at Coco Maya by Miss Bs in Little Italy San Diego. Book online or call ${SITE.phone.display}. 1660 India St.`}
  image="/images/venue-hero-bar.jpg"
>
  <Nav />
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/venue-hero-bar.jpg"
        alt="Coco Maya Little Italy San Diego"
        class="w-full h-full object-cover"
        width="1800" height="1200"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/55 to-black/25"></div>
    </div>
    <div class="relative z-10 w-full max-w-6xl mx-auto px-6 lg:px-10 py-36 grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="eyebrow-light">Book Your Table</span>
        <h1 class="font-[family-name:var(--font-display)] italic text-[clamp(3.5rem,8vw,6rem)] text-white leading-none mb-3">
          Reservations
          <span class="block font-[family-name:var(--font-stamp)] not-italic text-[clamp(0.95rem,2.2vw,1.35rem)] tracking-[0.08em] text-white/75 mt-3">
            Coco Maya | Little Italy, San Diego
          </span>
        </h1>
        <p class="font-[family-name:var(--font-script)] text-white/65 text-3xl mb-8">at Coco Maya</p>
        <p class="font-[family-name:var(--font-body)] text-white/70 max-w-md leading-relaxed mb-11">
          Reserve your table online or call us directly. Walk-ins always welcome based on availability.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">Book Online</a>
          <a href={`tel:${SITE.phone.tel}`} class="btn-white">{SITE.phone.display}</a>
        </div>
      </div>
      <div class="bg-white/8 backdrop-blur-md border border-white/18 p-8">
        <span class="eyebrow-light mb-6">Hours</span>
        <div class="divide-y divide-white/10">
          {SITE.hours.map((h) => (
            <div class:list={[
              "flex justify-between py-3.5 font-[family-name:var(--font-body)] text-sm",
              h.day === todayName ? "text-white" : "text-white/40"
            ]}>
              <span class:list={[h.day === todayName ? "text-[var(--color-teal-light)] font-medium" : ""]}>{h.day}</span>
              <span>{h.hours}</span>
            </div>
          ))}
        </div>
        <div class="border-t border-white/10 mt-4 pt-4">
          <p class="font-[family-name:var(--font-body)] text-white/45 text-xs leading-relaxed">
            Brunch Daily, Until 3PM &bull; Rooftop Patio Open Daily
          </p>
        </div>
      </div>
    </div>
  </section>
  <Footer />
</BaseLayout>
