---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import CTASection from "../../components/CTASection.astro";
import InfoCard from "../../components/InfoCard.astro";
import { SITE } from "../../data/site";
import { FEATURED_BRUNCH } from "../../data/menu";
---
<BaseLayout
  title="Best Brunch Little Italy San Diego | Coco Maya | Sat & Sun 11AM-3PM"
  description="Weekend brunch at Coco Maya in Little Italy San Diego. Bottomless options, coastal Mexican brunch plates, and craft cocktails. Saturday and Sunday 11AM-3PM."
  image="/images/food-brunch-sandwich.jpg"
>
  <Nav />
  <PageHero
    label="Saturday & Sunday"
    title="Weekend Brunch"
    subtitle="San Diego best brunch in Little Italy. Coastal Mexican plates, bottomless options, and craft cocktails on the elevated patio."
    image="/images/food-tacos-patio.jpg"
    imageAlt="Brunch at Coco Maya Little Italy San Diego"
    tall={true}
  />

  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-4xl mx-auto">

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-20">
        <InfoCard label="Days" value={SITE.brunch.days} />
        <InfoCard label="Hours" value={SITE.brunch.hours} accent={true} />
        <InfoCard label="Location" value="Little Italy" sub="1660 India St, San Diego" />
      </div>

      <span class="eyebrow">On the Menu</span>
      <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-10">Brunch Favorites</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {FEATURED_BRUNCH.map((item) => (
          <div class="cm-media-card group flex gap-0 flex-col sm:flex-row">
            <div class="w-full sm:w-32 flex-shrink-0 overflow-hidden aspect-square sm:aspect-auto">
              <img src={item.image} alt={item.name} class="w-full h-full object-cover" width="128" height="128" loading="lazy" />
            </div>
            <div class="p-5 flex-1">
              <h3 class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-lg mb-1.5">{item.name}</h3>
              <div class="w-5 h-px bg-[var(--color-teal)] mb-2"></div>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/50 text-xs leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Join Us for Brunch"
    subtitle="Reserve your weekend brunch table at Coco Maya in Little Italy."
    primaryLabel="Reserve a Table"
    primaryHref={SITE.reservations.url}
    secondaryLabel="View Full Menu"
    secondaryHref="/menu"
    dark={true}
  />
  <Footer />
</BaseLayout>
