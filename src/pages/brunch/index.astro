---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import CTASection from "../../components/CTASection.astro";
import InfoCard from "../../components/InfoCard.astro";
import { SITE } from "../../data/site";
import { FEATURED_BRUNCH } from "../../data/menu";

const highlights = [
  { icon: "🥂", label: "Bottomless Brunch", body: "Bottomless mimosas, bloody marys, and select cocktails available every Saturday and Sunday." },
  { icon: "🌮", label: "Modern Coastal Plates", body: "Fresh seafood, seasonal produce, and elevated brunch classics from the Coco Maya kitchen." },
  { icon: "🌿", label: "The Elevated Patio", body: "Brunch on one of San Diego most distinctive patios. Pink striped umbrellas, tropical greenery, and the Little Italy skyline." },
];

const drinks = [
  { name: "Bottomless Mimosas", description: "Classic, mango, or hibiscus. Keep them coming." },
  { name: "Bloody Maya", description: "House bloody mary with mezcal, tajin rim, and fresh garnish." },
  { name: "Paloma Spritz", description: "Tequila, fresh grapefruit, agave, sparkling water." },
  { name: "Morning Margarita", description: "Blanco tequila, fresh lime, agave, salted rim." },
];
---
<BaseLayout
  title="Best Brunch in Little Italy San Diego | Coco Maya | Sat & Sun 11AM–3PM"
  description="Best brunch in Little Italy San Diego at Coco Maya. Bottomless mimosas on the rooftop patio every Saturday & Sunday 11AM–3PM. 1660 India St, San Diego CA 92101."
  image="/images/food-tacos-patio.jpg"
>
  <Nav />

  <PageHero
    label="Saturday and Sunday"
    title="Weekend Brunch"
    subtitle="San Diego best brunch in Little Italy. Modern coastal plates, bottomless options, and craft cocktails on the elevated patio."
    image="/images/food-tacos-patio.jpg"
    imageAlt="Brunch at Coco Maya Little Italy San Diego"
    tall={true}
  >
    <div class="flex flex-wrap gap-4 mt-8">
      <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">Reserve a Table</a>
      <a href="#menu" class="btn-ghost">See the Menu</a>
    </div>
  </PageHero>

  <!-- INFO CARDS -->
  <section class="py-16 px-6 bg-[var(--color-cream)]">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-5">
      <InfoCard label="Days" value={SITE.brunch.days} />
      <InfoCard label="Hours" value={SITE.brunch.hours} accent={true} />
      <InfoCard label="Location" value="Little Italy" sub="1660 India St, San Diego" />
    </div>
  </section>

  <div class="cm-divider"></div>

  <!-- WHAT MAKES IT SPECIAL -->
  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="eyebrow">Brunch · Little Italy San Diego</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.25rem,4vw,3.5rem)] text-[var(--color-dark)] leading-tight mb-6">
          San Diego brunch done the right way
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-5">
          Weekend brunch at Coco Maya is not just a meal. It is a setting. The glass atrium opens to the San Diego sky, the elevated patio fills with tropical greenery, and the kitchen sends out plates that actually earn the word elevated.
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-10">
          Whether you are celebrating something or just making Saturday morning count, the patio at 1660 India St is the right call. Brunch every Saturday and Sunday from 11 AM to 3 PM.
        </p>
        <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">Reserve Your Table</a>
      </div>
      <div class="relative">
        <img
          src="/images/venue-patio.jpg"
          alt="Rooftop patio brunch at Coco Maya — best brunch Little Italy San Diego"
          class="w-full aspect-[4/5] object-cover"
          width="700" height="875" loading="lazy"
        />
        <div class="absolute -bottom-4 -right-4 w-full h-full border border-[var(--color-teal)]/20 -z-10 pointer-events-none"></div>
      </div>
    </div>
  </section>

  <!-- HIGHLIGHTS -->
  <section class="py-20 px-6 bg-[var(--color-sand-dark)]/30">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <span class="eyebrow">What to Expect</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3rem)] text-[var(--color-dark)]">Everything you need for a great morning</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {highlights.map((h) => (
          <div class="cm-card">
            <p class="text-3xl mb-4">{h.icon}</p>
            <span class="eyebrow">{h.label}</span>
            <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/60 text-sm leading-relaxed">{h.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FULL BLEED ATMOSPHERE IMAGE -->
  <section class="relative h-[50vh] overflow-hidden">
    <img
      src="/images/cocktail-happy-hour-group.jpg"
      alt="Coco Maya rooftop patio — brunch and happy hour in Little Italy San Diego"
      class="w-full h-full object-cover object-center"
      width="1800" height="800" loading="lazy"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.2) 60%, rgba(0,0,0,0.05) 100%);"></div>
    <div class="absolute inset-0 flex items-center px-8 md:px-20">
      <div class="max-w-lg">
        <span class="eyebrow-light">Daily Happy Hour too</span>
        <p class="font-[family-name:var(--font-display)] italic text-white text-[clamp(2rem,4vw,3.25rem)] leading-tight">
          Stay for Happy Hour.<br />Every day, 3 to 5 PM.
        </p>
        <a href="/happy-hour" class="btn-ghost mt-8 inline-flex">See Happy Hour Details</a>
      </div>
    </div>
  </section>

  <!-- BRUNCH DRINKS -->
  <section class="py-24 px-6 bg-[var(--color-dark)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="eyebrow-light">Brunch Drinks</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.25rem)] text-white leading-tight mb-6">
          Bottomless and worth it
        </h2>
        <div class="rule-light"></div>
        <p class="font-[family-name:var(--font-body)] text-white/55 leading-relaxed mb-10">
          Bottomless brunch options available every Saturday and Sunday. Classic mimosas, bloody marys, and Coco Maya originals. Add bottomless to any brunch reservation.
        </p>
        <div class="space-y-0 divide-y divide-white/8">
          {drinks.map((drink) => (
            <div class="py-4 grid grid-cols-[1fr_auto] gap-4 items-start">
              <div>
                <p class="font-[family-name:var(--font-display)] italic text-white text-lg leading-tight">{drink.name}</p>
                <p class="font-[family-name:var(--font-body)] text-white/45 text-sm mt-1">{drink.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="relative">
        <img
          src="/images/cocktail-patio-pair.jpg"
          alt="Bottomless brunch mimosas and cocktails — Coco Maya Little Italy San Diego"
          class="w-full aspect-square object-cover"
          width="700" height="700" loading="lazy"
        />
        <div class="absolute -top-4 -left-4 w-full h-full border border-[var(--color-teal)]/25 -z-10 pointer-events-none"></div>
      </div>
    </div>
  </section>

  <!-- BRUNCH MENU -->
  <section id="menu" class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12">
        <span class="eyebrow">On the Menu</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)]">Brunch Favorites</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-12">
        {FEATURED_BRUNCH.map((item) => (
          <div class="cm-media-card group flex flex-col sm:flex-row">
            <div class="w-full sm:w-32 flex-shrink-0 overflow-hidden aspect-square sm:aspect-auto">
              <img
                src={item.image}
                alt={item.name}
                class="w-full h-full object-cover"
                width="128" height="128" loading="lazy"
              />
            </div>
            <div class="p-5 flex-1">
              <h3 class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-lg mb-1.5">{item.name}</h3>
              <div class="w-5 h-px bg-[var(--color-teal)] mb-2.5"></div>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/50 text-xs leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center">
        <a href="/menu" class="btn-outline">View Full Menu</a>
      </div>
    </div>
  </section>

  <!-- PRIVATE BRUNCH CALLOUT -->
  <section class="py-20 px-6 bg-[var(--color-sand-dark)]/30">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8">
      <div class="cc-card">
        <div class="cc-card__bar"></div>
        <div class="cc-card__body">
          <span class="cc-card__label">Private Brunch Events</span>
          <p class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-2xl mb-2">Brunch buyouts for groups</p>
          <p class="cc-card__text">Birthdays, bachelorettes, baby showers. Book a private brunch for your group on the patio or in the dining room.</p>
          <a href="/private-events" class="btn-outline mt-6 self-start">Learn More</a>
        </div>
      </div>
      <div class="cc-card">
        <div class="cc-card__bar"></div>
        <div class="cc-card__body">
          <span class="cc-card__label">Make a Reservation</span>
          <p class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-2xl mb-2">Reserve your table now</p>
          <p class="cc-card__text">Saturday and Sunday 11 AM to 3 PM. Book online or call us directly. Walk-ins welcome based on availability.</p>
          <div class="flex flex-wrap gap-4 mt-6">
            <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">Book Online</a>
            <a href={`tel:${SITE.phone.tel}`} class="btn-outline">{SITE.phone.display}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Join Us for Brunch"
    subtitle="1660 India St, Little Italy San Diego. Saturday and Sunday 11AM to 3PM."
    primaryLabel="Reserve a Table"
    primaryHref={SITE.reservations.url}
    secondaryLabel="View Full Menu"
    secondaryHref="/menu"
    dark={true}
  />
  <Footer />
</BaseLayout>
