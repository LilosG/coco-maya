---
import Picture from "../../components/Picture.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import CTASection from "../../components/CTASection.astro";
import InfoCard from "../../components/InfoCard.astro";
import MenuShowcase from "../../components/MenuShowcase.astro";
import { getOrderedCollection, getSingleton } from "../../lib/content";
import { breadcrumbSchema } from "../../lib/schema";

const [SITE, page, FEATURED_BRUNCH, FEATURED_BRUNCH_DRINKS] = await Promise.all([getSingleton("siteSettings"), getSingleton("brunchPage"), getOrderedCollection("menuBrunchFood"), getOrderedCollection("menuBrunchDrinks")]);
const fill = (value: string, name?: string) => value.replaceAll("{{street}}", SITE.address.street).replaceAll("{{fullAddress}}", `${SITE.address.street}, ${SITE.address.city} ${SITE.address.state} ${SITE.address.zip}`).replaceAll("{{brunchDailyUntil3}}", SITE.serviceMessaging.brunchDailyUntil3).replaceAll("{{name}}", name ?? "");
const highlights = page.highlights ?? [];
const dayNames = SITE.weekdaysSundayFirst ?? [];
const todayName = dayNames[new Date().getDay()];
const schema = [
  breadcrumbSchema([
    { name: SITE.breadcrumbs.home, url: SITE.url },
    { name: page.breadcrumbLabel, url: `${SITE.url}/brunch` },
  ]),
];
---
<BaseLayout
  title={page.seo.title}
  description={fill(page.seo.descriptionTemplate)}
  image={page.seo.image}
  extraSchema={schema}
>
  <Nav />

  <PageHero
    label={page.hero.label}
    title={page.hero.title}
    titleSuffix={page.hero.titleSuffix}
    subtitle={page.hero.subtitle}
    image={page.hero.image}
    imageAlt={page.hero.imageAlt}
    tall={true}
  >
    <div class="flex flex-wrap gap-4 mt-8">
      <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">{page.hero.reserveLabel}</a>
      <a href="#menu" class="btn-ghost">{page.hero.menuLabel}</a>
    </div>
  </PageHero>

  <!-- INFO CARDS -->
  <section class="py-16 px-6 bg-[var(--color-cream)]">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-5 mb-10">
      {(page.infoCards ?? []).map((card: any) => <InfoCard label={card.label} value={card.value} sub={card.subTemplate ? fill(card.subTemplate) : undefined} accent={card.accent} />)}
    </div>

    <!-- FULL BRUNCH HOURS BY DAY (hours vary by day of week, per GBP) -->
    <div class="max-w-4xl mx-auto bg-white border border-[var(--color-teal)]/12">
      <div class="px-6 pt-6 pb-2">
        <span class="eyebrow">{page.hoursLabel}</span>
      </div>
      <div class="divide-y divide-[var(--color-teal)]/10 px-6 pb-6">
        {(SITE.service.brunch.days ?? []).map((d: any) => (
          <div class:list={[
            "flex justify-between py-3 font-[family-name:var(--font-body)] text-sm",
            d.day === todayName ? "text-[var(--color-dark)]" : "text-[var(--color-dark)]/50"
          ]}>
            <span class:list={[d.day === todayName ? "text-[var(--color-teal)] font-medium" : ""]}>{d.day}</span>
            <span>{d.hours}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BRUNCH FAVORITES SHOWCASE -->
  <div id="menu">
    <MenuShowcase
      eyebrow={page.favorites.eyebrow}
      title={page.favorites.title}
      items={FEATURED_BRUNCH.map((item) => ({
        name: item.name,
        description: item.description,
        image: item.image,
        imageAlt: fill(page.favorites.imageAltTemplate, item.name),
      }))}
      ctaLabel={page.favorites.ctaLabel}
      ctaHref="/menu"
    />
  </div>

  <div class="cm-divider"></div>

  <!-- WHAT MAKES IT SPECIAL -->
  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <span class="eyebrow">{page.intro.eyebrow}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2.25rem,4vw,3.5rem)] text-[var(--color-dark)] leading-tight mb-6">
          {page.intro.title}
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-5">
          {page.intro.body1}
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-10">
          {fill(page.intro.body2Template)}
        </p>
        <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">{page.intro.reserveLabel}</a>
      </div>
      <div class="relative">
        <Picture
          src={page.intro.image}
          alt={page.intro.imageAlt}
          class="w-full aspect-[4/5] object-cover"
          width="700" height="875" loading="lazy"
        />
        <div class="absolute -bottom-4 -right-4 w-full h-full border border-[var(--color-teal)]/20 -z-10 pointer-events-none"></div>
      </div>
    </div>
  </section>

  <!-- HIGHLIGHTS -->
  <section class="py-20 px-6 bg-[var(--color-sand-dark)]/30">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <span class="eyebrow">{page.highlightsHeading.eyebrow}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3rem)] text-[var(--color-dark)]">{page.highlightsHeading.title}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {highlights.map((h: any) => (
          <div class="cm-card">
            <p class="text-3xl mb-4">{h.icon}</p>
            <span class="eyebrow">{h.label}</span>
            <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/60 text-sm leading-relaxed">{h.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FULL BLEED ATMOSPHERE IMAGE -->
  <section class="relative h-[50vh] overflow-hidden">
    <Picture
      src={page.atmosphere.image}
      alt={page.atmosphere.imageAlt}
      class="w-full h-full object-cover object-center"
      width="1800" height="800" loading="lazy"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.2) 60%, rgba(0,0,0,0.05) 100%);"></div>
    <div class="absolute inset-0 flex items-center px-8 md:px-20">
      <div class="max-w-lg">
        <span class="eyebrow-light">{page.atmosphere.eyebrow}</span>
        <p class="font-[family-name:var(--font-display)] italic text-white text-[clamp(2rem,4vw,3.25rem)] leading-tight">
          {page.atmosphere.line.split("\n")[0]}<br />{page.atmosphere.line.split("\n")[1]}
        </p>
        <a href="/happy-hour" class="btn-ghost mt-8 inline-flex">{page.atmosphere.ctaLabel}</a>
      </div>
    </div>
  </section>

  <!-- BRUNCH DRINKS -->
  <MenuShowcase
    eyebrow={page.drinks.eyebrow}
    title={page.drinks.title}
    subtitle={page.drinks.subtitle}
    items={FEATURED_BRUNCH_DRINKS.map((drink) => ({
      name: drink.name,
      description: drink.description,
      image: drink.image,
      imageAlt: fill(page.drinks.imageAltTemplate, drink.name),
    }))}
    dark={true}
  />

  <!-- PRIVATE BRUNCH CALLOUT -->
  <section class="py-20 px-6 bg-[var(--color-sand-dark)]/30">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8">
      <div class="cc-card">
        <div class="cc-card__bar"></div>
        <div class="cc-card__body">
          <span class="cc-card__label">{page.cards.private.label}</span>
          <p class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-2xl mb-2">{page.cards.private.title}</p>
          <p class="cc-card__text">{page.cards.private.body}</p>
          <a href="/private-events" class="btn-outline mt-6 self-start">{page.cards.private.ctaLabel}</a>
        </div>
      </div>
      <div class="cc-card">
        <div class="cc-card__bar"></div>
        <div class="cc-card__body">
          <span class="cc-card__label">{page.cards.reservation.label}</span>
          <p class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-2xl mb-2">{page.cards.reservation.title}</p>
          <p class="cc-card__text">{page.cards.reservation.body}</p>
          <div class="flex flex-wrap gap-4 mt-6">
            <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">{page.cards.reservation.ctaLabel}</a>
            <a href={`tel:${SITE.phone.tel}`} class="btn-outline">{SITE.phone.display}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title={page.cta.title}
    subtitle={fill(page.cta.subtitleTemplate)}
    primaryLabel={page.cta.primaryLabel}
    primaryHref={SITE.reservations.url}
    secondaryLabel={page.cta.secondaryLabel}
    secondaryHref="/menu"
    dark={true}
  />
  <Footer />
</BaseLayout>
