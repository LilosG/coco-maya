---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import CTASection from "../../components/CTASection.astro";
import EventInquiryForm from "../../components/EventInquiryForm.astro";
import { SITE } from "../../data/site";
import { RECURRING_EVENTS } from "../../data/events";
---
<BaseLayout
  title="Events | Coco Maya | Little Italy San Diego"
  description="Events at Coco Maya in Little Italy San Diego. Weekend brunch, happy hour, and private events. 1660 India St."
  image="/images/events-patio-night.jpg"
>
  <Nav />
  <PageHero
    label="Weekly and Special"
    title="Events at Coco Maya"
    subtitle="Weekend brunch, daily happy hour, and private events in Little Italy."
    image="/images/events-patio-night.jpg"
    imageAlt="Evening event at Coco Maya patio Little Italy San Diego"
    tall={true}
  />

  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-6xl mx-auto">
      <div class="mb-16">
        <span class="eyebrow">Weekly</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)]">Recurring Events</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {RECURRING_EVENTS.map((event) => (
          <div class="cm-media-card group">
            <div class="relative aspect-video overflow-hidden">
              <img
                src={event.image}
                alt={`${event.name} at Coco Maya Little Italy San Diego`}
                class="w-full h-full object-cover"
                width="800" height="450"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-transparent to-transparent"></div>
              <div class="absolute bottom-4 left-4">
                <span class="bg-[var(--color-teal)] text-white font-[family-name:var(--font-stamp)] text-xs tracking-widest uppercase px-3 py-1.5">
                  {event.highlight}
                </span>
              </div>
            </div>
            <div class="p-7">
              <h3 class="font-[family-name:var(--font-display)] italic text-[var(--color-dark)] text-2xl mb-2">{event.name}</h3>
              <div class="flex items-center gap-3 mb-4">
                <div class="w-4 h-px bg-[var(--color-teal)]"></div>
                <span class="eyebrow mb-0">{event.day} &bull; {event.time}</span>
              </div>
              <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/55 text-sm leading-relaxed">{event.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-dark)] px-6 py-0">
    <div class="max-w-4xl mx-auto cm-dark-grid" style="grid-template-columns: 1fr 1fr;">
      <div class="cm-dark-grid-cell py-14 text-left">
        <span class="eyebrow-light mb-4">Private Events</span>
        <h3 class="font-[family-name:var(--font-display)] italic text-white text-3xl mb-4">Host Your Own Event</h3>
        <p class="font-[family-name:var(--font-body)] text-white/50 leading-relaxed mb-8 text-sm">
          Birthdays, bachelorettes, rehearsal dinners, corporate events. Coco Maya has a private event space in Little Italy your guests will remember.
        </p>
        <a href="/private-events" class="btn-primary">Learn More</a>
      </div>
      <div class="cm-dark-grid-cell py-14 text-left">
        <span class="eyebrow-light mb-4">Reservations</span>
        <h3 class="font-[family-name:var(--font-display)] italic text-white text-3xl mb-4">Book a Table</h3>
        <p class="font-[family-name:var(--font-body)] text-white/50 leading-relaxed mb-8 text-sm">
          Reserve your table online. Walk-ins welcome based on availability. Open daily in Little Italy at 1660 India St.
        </p>
        <a href={SITE.reservations.url} target="_blank" rel="noopener noreferrer" class="btn-primary">Reserve Now</a>
      </div>
    </div>
  </section>

  <EventInquiryForm
    label="Plan a Private Event"
    subtitle="Share your date, headcount, and event type below and we'll follow up within 24 hours."
  />

  <CTASection
    title="See You at Coco Maya"
    subtitle="1660 India St, Little Italy San Diego. Open daily."
    primaryLabel="Reserve a Table"
    primaryHref={SITE.reservations.url}
    secondaryLabel="Private Events"
    secondaryHref="/private-events"
  />
  <Footer />
</BaseLayout>
