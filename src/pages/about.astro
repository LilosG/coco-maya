---
import Picture from "../components/Picture.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import CTASection from "../components/CTASection.astro";
import { getSingleton, resolveSiteTokens } from "../lib/content";
import { breadcrumbSchema } from "../lib/schema";

const [SITE, rawAbout] = await Promise.all([getSingleton("siteSettings"), getSingleton("about")]);
const about = resolveSiteTokens(rawAbout, SITE);
const fill = (value: string) => value.replaceAll("{{street}}", SITE.address.street);
const stats = about.stats;
const schema = [
  breadcrumbSchema([
    { name: SITE.breadcrumbs.home, url: SITE.url },
    { name: about.breadcrumbLabel, url: `${SITE.url}/about` },
  ]),
];
---
<BaseLayout
  title={about.seo.title}
  description={fill(about.seo.descriptionTemplate)}
  image={about.seo.image}
  extraSchema={schema}
>
  <Nav />
  <PageHero
    label={about.hero.label}
    title={about.hero.title}
    titleSuffix={about.hero.titleSuffix}
    subtitle={about.hero.subtitle}
    image={about.hero.image}
    imageAlt={about.hero.imageAlt}
    tall={true}
  />

  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-20 items-center">
      <div>
        <span class="eyebrow">{about.story.eyebrow}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] leading-tight mb-4">
          {about.story.title}
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-4 text-[1.0625rem]">
          {fill(about.story.body1Template)}
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-4 text-[1.0625rem]">
          {about.story.body2}
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-10 text-[1.0625rem]">
          {about.story.body3}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/the-space" class="btn-primary">{about.story.primaryLabel}</a>
          <a href="/menu" class="btn-outline">{about.story.secondaryLabel}</a>
        </div>
      </div>
      <div class="relative">
        <Picture
          src={about.story.image}
          alt={about.story.imageAlt}
          class="w-full aspect-[4/5] object-cover"
          width="700" height="875"
          loading="lazy"
        />
        <div class="absolute -bottom-5 -right-5 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-dark)] px-6 py-20">
    <div class="max-w-5xl mx-auto">
      <span class="eyebrow-light mx-auto block text-center mb-12">{about.statsLabel}</span>
      <div class="cm-dark-grid" style="grid-template-columns: repeat(4, 1fr);">
        {stats.map((s: any) => (
          <div class="cm-dark-grid-cell py-12">
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-teal-light)] text-3xl mb-2">{s.value}</p>
            <p class="font-[family-name:var(--font-stamp)] text-white text-xs tracking-widest uppercase mb-1">{s.label}</p>
            <p class="font-[family-name:var(--font-body)] text-white/35 text-xs">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-20 items-center">
      <div class="relative order-2 lg:order-1">
        <Picture
          src={about.experience.image}
          alt={about.experience.imageAlt}
          class="w-full aspect-[4/5] object-cover"
          width="700" height="875"
          loading="lazy"
        />
        <div class="absolute -top-5 -left-5 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
      </div>
      <div class="order-1 lg:order-2">
        <span class="eyebrow">{about.experience.eyebrow}</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-4 leading-tight">
          {about.experience.title}
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-4 text-[1.0625rem]">
          {about.experience.body1}
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed text-[1.0625rem]">
          {about.experience.body2}
        </p>
      </div>
    </div>
  </section>

  <CTASection
    title={about.cta.title}
    subtitle={fill(about.cta.subtitleTemplate)}
    primaryLabel={about.cta.primaryLabel}
    primaryHref={SITE.reservations.url}
    secondaryLabel={about.cta.secondaryLabel}
    secondaryHref={SITE.address.mapsUrl}
    dark={true}
  />
  <Footer />
</BaseLayout>
