---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import CTASection from "../components/CTASection.astro";
import { SITE } from "../data/site";

const stats = [
  { value: "1660",       label: "India Street",    sub: "Little Italy, San Diego" },
  { value: "Open Daily", label: "Every Week",       sub: "Mon-Thu 10:30 AM on" },
  { value: "3-5 PM",     label: "Happy Hour",       sub: "Every day of the week" },
  { value: "Sat & Sun",  label: "Weekend Brunch",   sub: "11:00 AM to 3:00 PM" },
];
---
<BaseLayout
  title="About | Coco Maya by Miss Bs | Little Italy San Diego"
  description="Coco Maya by Miss Bs is an elevated modern American coastal restaurant in Little Italy San Diego. Glass atrium, elevated patio, craft cocktails. 1660 India St."
  image="/images/venue-interior-dining.jpg"
>
  <Nav />
  <PageHero
    label="Our Story"
    title="About Coco Maya"
    subtitle="Elevated modern American coastal cuisine in the heart of Little Italy, San Diego."
    image="/images/venue-interior-dining.jpg"
    imageAlt="Coco Maya dining room Little Italy San Diego"
    tall={true}
  />

  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-20 items-center">
      <div>
        <span class="eyebrow">The Concept</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] leading-tight mb-4">
          Modern Coastal, Elevated
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-4 text-[1.0625rem]">
          Coco Maya by Miss Bs is San Diego elevated modern American coastal dining destination. Situated at 1660 India St in the heart of Little Italy, the restaurant is built around a stunning glass atrium bar, an elevated outdoor patio, and a kitchen that takes the food as seriously as the cocktails.
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-4 text-[1.0625rem]">
          The menu draws from modern American coastal culinary traditions — fresh seafood, bold flavors, and elevated classics — executed with fine dining precision in a setting that feels genuinely relaxed.
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-10 text-[1.0625rem]">
          Daily happy hour, weekend brunch, private events, and a cocktail program that draws from agave traditions and tropical coastal flavors.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/the-space" class="btn-primary">See The Space</a>
          <a href="/menu" class="btn-outline">View the Menu</a>
        </div>
      </div>
      <div class="relative">
        <img
          src="/images/venue-neon-sign.jpg"
          alt="In Love with the Coco neon sign at Coco Maya Little Italy San Diego"
          class="w-full aspect-[4/5] object-cover"
          width="700" height="875"
          loading="lazy"
        />
        <div class="absolute -bottom-5 -right-5 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-dark)] px-6 py-20">
    <div class="max-w-5xl mx-auto">
      <span class="eyebrow-light mx-auto block text-center mb-12">At a Glance</span>
      <div class="cm-dark-grid" style="grid-template-columns: repeat(4, 1fr);">
        {stats.map((s) => (
          <div class="cm-dark-grid-cell py-12">
            <p class="font-[family-name:var(--font-display)] italic text-[var(--color-teal-light)] text-3xl mb-2">{s.value}</p>
            <p class="font-[family-name:var(--font-stamp)] text-white text-xs tracking-widest uppercase mb-1">{s.label}</p>
            <p class="font-[family-name:var(--font-body)] text-white/35 text-xs">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-20 items-center">
      <div class="relative order-2 lg:order-1">
        <img
          src="/images/venue-bar-to-patio.jpg"
          alt="Coco Maya bar looking out to the elevated patio in Little Italy"
          class="w-full aspect-[4/5] object-cover"
          width="700" height="875"
          loading="lazy"
        />
        <div class="absolute -top-5 -left-5 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
      </div>
      <div class="order-1 lg:order-2">
        <span class="eyebrow">The Experience</span>
        <h2 class="font-[family-name:var(--font-display)] italic text-[clamp(2rem,4vw,3.5rem)] text-[var(--color-dark)] mb-4 leading-tight">
          Indoor meets outdoor in the heart of Little Italy
        </h2>
        <div class="rule"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed mb-4 text-[1.0625rem]">
          The glass atrium bar connects seamlessly to the elevated outdoor patio. The design reflects the San Diego climate with lush botanical elements, warm natural materials, and a teal palette that ties the whole venue together.
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)]/65 leading-relaxed text-[1.0625rem]">
          Whether at the bar for happy hour or seated on the patio for a private dinner, Coco Maya is a space that makes every occasion feel considered.
        </p>
      </div>
    </div>
  </section>

  <CTASection
    title="Come Experience It"
    subtitle="1660 India St, Little Italy San Diego. Open daily."
    primaryLabel="Reserve a Table"
    primaryHref={SITE.reservations.url}
    secondaryLabel="Get Directions"
    secondaryHref={SITE.address.mapsUrl}
    dark={true}
  />
  <Footer />
</BaseLayout>
