---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import CTASection from "../components/CTASection.astro";
import { SITE } from "../data/site";

const stats = [
  { value: "1660", label: "India Street", sub: "Little Italy, San Diego" },
  { value: "Open Daily", label: "Mon-Thu 10:30AM", sub: "Fri-Sun from 9AM" },
  { value: "Daily 3-5", label: "Happy Hour", sub: "Every day of the week" },
  { value: "Sat and Sun", label: "Weekend Brunch", sub: "11:00 AM to 3:00 PM" },
];
---
<BaseLayout
  title="About | Coco Maya by Miss Bs | Little Italy San Diego"
  description="Coco Maya by Miss Bs is an elevated coastal Mexican restaurant in Little Italy San Diego. Glass atrium, elevated patio, craft cocktails. 1660 India St."
  image="/images/venue-interior-dining.jpg"
>
  <Nav />
  <PageHero
    label="Our Story"
    title="About Coco Maya"
    subtitle="Elevated coastal Mexican cuisine in the heart of Little Italy, San Diego."
    image="/images/venue-interior-dining.jpg"
    imageAlt="Coco Maya dining room Little Italy San Diego"
    tall={true}
  />

  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <p class="section-label mb-4">The Concept</p>
        <h2 class="font-[family-name:var(--font-display)] text-4xl sm:text-5xl text-[var(--color-dark)] italic leading-tight mb-6">
          Coastal Mexican, Elevated
        </h2>
        <div class="w-10 h-px bg-[var(--color-teal)] mb-6"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)] opacity-70 leading-relaxed mb-4">
          Coco Maya by Miss Bs is San Diego elevated coastal Mexican dining destination. Situated at 1660 India St in the heart of Little Italy, the restaurant is built around a stunning glass atrium bar, an elevated outdoor patio, and a kitchen that takes the food as seriously as the cocktails.
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)] opacity-70 leading-relaxed mb-4">
          The menu draws from coastal Mexican culinary traditions including fresh seafood, bold sauces, and house-made tortillas, elevated with the creativity and execution of a fine dining kitchen served in a setting that feels genuinely relaxed.
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)] opacity-70 leading-relaxed mb-10">
          Daily happy hour, weekend brunch, private events, and a cocktail program that draws from agave traditions and tropical coastal flavors.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/the-space" class="btn-primary">See The Space</a>
          <a href="/menu" class="btn-outline">View the Menu</a>
        </div>
      </div>
      <div class="relative">
        <img src="/images/venue-neon-sign.jpg"
          alt="In Love with the Coco neon sign at Coco Maya Little Italy San Diego"
          class="w-full aspect-[4/5] object-cover" width="700" height="875" loading="lazy" />
        <div class="absolute -bottom-4 -right-4 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-[var(--color-dark)] px-6">
    <div class="max-w-5xl mx-auto">
      <p class="section-label text-[var(--color-teal-light)] mb-10 text-center">At a Glance</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-white/10">
        {stats.map((s) => (
          <div class="bg-[var(--color-dark)] py-10 px-6 text-center">
            <p class="font-[family-name:var(--font-display)] text-3xl text-[var(--color-teal-light)] italic mb-2">{s.value}</p>
            <p class="font-[family-name:var(--font-stamp)] text-white text-xs tracking-widest uppercase mb-1">{s.label}</p>
            <p class="font-[family-name:var(--font-body)] text-white/40 text-xs">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="relative order-2 lg:order-1">
        <img src="/images/venue-bar-to-patio.jpg"
          alt="Coco Maya bar looking out to the elevated patio in Little Italy"
          class="w-full aspect-[4/5] object-cover" width="700" height="875" loading="lazy" />
        <div class="absolute -top-4 -left-4 w-full h-full border border-[var(--color-teal)]/20 -z-10"></div>
      </div>
      <div class="order-1 lg:order-2">
        <p class="section-label mb-4">The Experience</p>
        <h2 class="font-[family-name:var(--font-display)] text-4xl text-[var(--color-dark)] italic mb-6">
          Indoor meets outdoor in the heart of Little Italy
        </h2>
        <div class="w-10 h-px bg-[var(--color-teal)] mb-6"></div>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)] opacity-70 leading-relaxed mb-4">
          The glass atrium bar connects seamlessly to the elevated outdoor patio. The design reflects the San Diego climate: lush botanical elements, warm natural materials, and a teal palette that ties the whole venue together.
        </p>
        <p class="font-[family-name:var(--font-body)] text-[var(--color-dark)] opacity-70 leading-relaxed">
          Whether at the bar for happy hour or seated on the patio for a private dinner, Coco Maya is a space that makes every occasion feel considered.
        </p>
      </div>
    </div>
  </section>

  <CTASection
    title="Come Experience It"
    subtitle="1660 India St, Little Italy San Diego. Open daily."
    primaryLabel="Reserve a Table"
    primaryHref={SITE.reservations.url}
    secondaryLabel="Get Directions"
    secondaryHref={SITE.address.mapsUrl}
    dark={true}
  />
  <Footer />
</BaseLayout>
