---
import "../styles/global.css";
import { SITE } from "../data/site";
import Analytics from "../components/Analytics.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  extraSchema?: Record<string, unknown>[];
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description = SITE.description,
  image = "/images/venue-hero-bar.jpg",
  noindex = false,
  extraSchema = [],
  type = "website",
  publishedTime,
  modifiedTime,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE.url);

// Group consecutive days that share identical hours into single
// OpeningHoursSpecification entries — the standard schema.org pattern,
// rather than one entry per day.
const orderedDays = ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"];
const hoursByDay = new Map(SITE.hours.map((h) => [h.day, h.hours]));

function parseHoursRange(hours: string) {
  const [open, close] = hours.split("–").map((s) => s.trim());
  const to24 = (t: string) => {
    const m = t.match(/(\d+):(\d+)\s*(AM|PM)/i);
    if (!m) return t;
    let [, hh, mm, ap] = m;
    let hour = parseInt(hh, 10) % 12;
    if (/PM/i.test(ap)) hour += 12;
    if (hour === 24) hour = 0;
    return `${String(hour).padStart(2, "0")}:${mm}`;
  };
  return { opens: to24(open), closes: to24(close === "12:00 AM" ? "11:59 PM" : close) };
}

const openingHoursSpecification: Record<string, unknown>[] = [];
let i = 0;
while (i < orderedDays.length) {
  const day = orderedDays[i];
  const hours = hoursByDay.get(day)!;
  const group = [day];
  let j = i + 1;
  while (j < orderedDays.length && hoursByDay.get(orderedDays[j]) === hours) {
    group.push(orderedDays[j]);
    j++;
  }
  const { opens, closes } = parseHoursRange(hours);
  openingHoursSpecification.push({
    "@type": "OpeningHoursSpecification",
    dayOfWeek: group.map((d) => `https://schema.org/${d}`),
    opens,
    closes,
  });
  i = j;
}

const schema = {
  "@context": "https://schema.org",
  "@type": SITE.schema.type,
  name: SITE.fullName,
  description: SITE.description,
  url: SITE.url,
  telephone: SITE.phone.tel,
  address: {
    "@type": "PostalAddress",
    streetAddress: SITE.address.street,
    addressLocality: SITE.address.city,
    addressRegion: SITE.address.state,
    postalCode: SITE.address.zip,
    addressCountry: "US",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: SITE.schema.geo.lat,
    longitude: SITE.schema.geo.lng,
  },
  priceRange: SITE.schema.priceRange,
  servesCuisine: SITE.schema.servesCuisine,
  hasMap: SITE.address.mapsUrl,
  sameAs: Object.values(SITE.social),
  openingHoursSpecification,
  acceptsReservations: true,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE.url}${image}`} />
    <meta property="og:site_name" content={SITE.fullName} />
    {type === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {type === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE.url}${image}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Dancing+Script:wght@600;700&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&family=Oswald:wght@400;500;600&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/png" href="/images/logo-teal.png" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
    {extraSchema.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} is:inline />
    ))}
    <Analytics />
  </head>
  <body>
    <slot />
  </body>
</html>
